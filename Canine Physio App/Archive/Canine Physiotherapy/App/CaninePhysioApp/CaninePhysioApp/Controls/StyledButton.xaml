<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CaninePhysioApp.Controls.StyledButton"
             x:Name="this"
             HorizontalOptions="{Binding Source={x:Reference this}, Path=ButtonHorizontalAlignment}">
    <Grid>
        <!-- Shadow layer -->
        <BoxView x:Name="ShadowBox"
                 BackgroundColor="{Binding Source={x:Reference this}, Path=ShadowColor}"
                 CornerRadius="{Binding Source={x:Reference this}, Path=ButtonCornerRadius}"
                 TranslationX="{Binding Source={x:Reference this}, Path=ShadowOffsetX}"
                 TranslationY="{Binding Source={x:Reference this}, Path=ShadowOffsetY}" />
        
        <!-- Main button -->
        <Button x:Name="MainButton"
                Text="{Binding Source={x:Reference this}, Path=Text}"
                Command="{Binding Source={x:Reference this}, Path=Command}"
                BackgroundColor="{Binding Source={x:Reference this}, Path=ButtonBackgroundColor}"
                TextColor="{Binding Source={x:Reference this}, Path=ButtonTextColor}"
                BorderColor="{Binding Source={x:Reference this}, Path=ButtonBorderColor}"
                BorderWidth="{Binding Source={x:Reference this}, Path=ButtonBorderWidth}"
                CornerRadius="{Binding Source={x:Reference this}, Path=ButtonCornerRadius}"
                MinimumHeightRequest="{Binding Source={x:Reference this}, Path=ButtonHeight}"
                Margin="{Binding Source={x:Reference this}, Path=ButtonMargin}"
                FontSize="{Binding Source={x:Reference this}, Path=ButtonFontSize}"
                FontFamily="{Binding Source={x:Reference this}, Path=ButtonFontFamily}"
                CharacterSpacing="{Binding Source={x:Reference this}, Path=ButtonCharacterSpacing}"
                FontAttributes="Bold"
                Padding="16,8"
                Pressed="OnButtonPressed"
                Released="OnButtonReleased" />
    </Grid>
</ContentView>
