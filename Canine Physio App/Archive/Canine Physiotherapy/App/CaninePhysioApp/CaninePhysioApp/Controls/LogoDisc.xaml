<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CaninePhysioApp.Controls.LogoDisc"
             x:Name="this">
    
    <!-- Proportional logo disc - all sizes derived from DiscSize -->
    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <!-- Shadow layer (slightly offset) -->
        <Ellipse x:Name="ShadowEllipse"
                 Fill="{StaticResource Shadow}" />
        
        <!-- White border circle -->
        <Ellipse x:Name="BorderEllipse"
                 Fill="{StaticResource Surface}" />
        
        <!-- Main disc background -->
        <Ellipse x:Name="BackgroundEllipse"
                 Fill="{StaticResource Primary}"
                 HorizontalOptions="Center"
                 VerticalOptions="Center" />
        
        <!-- Dog logo image -->
        <Image x:Name="LogoImage"
               Source="hellobuddy_logo.png"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Aspect="AspectFit" />
        
        <!-- Getting Better text - uses CharacterSpacing instead of manual spaces -->
        <Label x:Name="GettingBetterLabel"
               Text="GETTING BETTER"
               Style="{StaticResource LogoDiscTextStyle}"
               CharacterSpacing="{StaticResource LogoDiscCharacterSpacing}"
               VerticalOptions="End" />
    </Grid>
</ContentView>
