<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CaninePhysioApp.Controls.HeaderBlock"
             x:Name="this"
             BackgroundColor="{StaticResource SafeArea}">
    
    <VerticalStackLayout Padding="20,5,20,20"
                         Spacing="{StaticResource SpacingS}">
        <Label Text="{Binding Source={x:Reference this}, Path=Title}"
               Style="{StaticResource PageTitleStyle}" />
        
        <Label Text="{Binding Source={x:Reference this}, Path=Subtitle}"
               Style="{StaticResource SubtitleStyle}"
               CharacterSpacing="0.4"
               LineBreakMode="TailTruncation"
               MaxLines="1"
               IsVisible="{Binding Source={x:Reference this}, Path=ShowSubtitle}" />
    </VerticalStackLayout>
</ContentView>
