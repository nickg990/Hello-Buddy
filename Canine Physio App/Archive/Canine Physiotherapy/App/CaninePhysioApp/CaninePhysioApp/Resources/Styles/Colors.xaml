<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================== -->
    <!-- COLORS RESOURCE DICTIONARY                     -->
    <!-- Centralised color palette for the app          -->
    <!-- Note: For Android see also                     -->
    <!-- Platforms\Android\Resources\values\colors.xml  -->
    <!-- ============================================== -->

    <!-- ============================================== -->
    <!-- BRAND / PRIMARY COLORS                         -->
    <!-- ============================================== -->
    <Color x:Key="Primary">#3D81A9</Color>
    <Color x:Key="PrimaryDark">#2C6080</Color>
    <Color x:Key="PrimaryLight">#5A9BC4</Color>
    <Color x:Key="Secondary">#D8CDA3</Color>
    <Color x:Key="Tertiary">#3D81A9</Color>
    <Color x:Key="MidnightBlue">#191970</Color>
    <Color x:Key="Magenta">#512BD4</Color>

    <!-- ============================================== -->
    <!-- SEMANTIC SURFACE COLORS                        -->
    <!-- ============================================== -->
    <Color x:Key="Surface">White</Color>
    <Color x:Key="CardBackground">White</Color>
    <Color x:Key="PageBackground">#D9D9D9</Color>
    <Color x:Key="PageBackgroundAlt">#B0CED8</Color>
    <Color x:Key="SafeArea">White</Color>
    <Color x:Key="HeaderTitle">#3D81A9</Color>

    <!-- ============================================== -->
    <!-- TEXT COLORS                                    -->
    <!-- ============================================== -->
    <Color x:Key="TextPrimary">Black</Color>
    <Color x:Key="TextSecondary">#555555</Color>
    <Color x:Key="TextMuted">#666666</Color>
    <Color x:Key="TextOnPrimary">White</Color>
    <Color x:Key="TextOnDark">White</Color>
    <Color x:Key="TextLink">#3D81A9</Color>
    <Color x:Key="PrimaryDarkText">#212121</Color>
    <Color x:Key="SecondaryDarkText">#CCCCCC</Color>

    <!-- ============================================== -->
    <!-- STATE COLORS (Error, Success, Warning)         -->
    <!-- ============================================== -->
    <Color x:Key="Error">#D9534F</Color>
    <Color x:Key="Success">#3CB371</Color>
    <Color x:Key="Warning">#F0AD4E</Color>
    <Color x:Key="Info">#4C86A8</Color>

    <!-- ============================================== -->
    <!-- BUTTON COLORS                                  -->
    <!-- ============================================== -->
    <Color x:Key="ButtonPrimary">#3D81A9</Color>
    <Color x:Key="ButtonPrimaryText">White</Color>
    <Color x:Key="ButtonSecondary">#D9D9D9</Color>
    <Color x:Key="ButtonSecondaryText">Black</Color>
    <Color x:Key="GhostButton">#D7F2FD</Color>
    <Color x:Key="GhostButtonText">Black</Color>
    <Color x:Key="Disabled">#CCCCCC</Color>
    <Color x:Key="DisabledText">White</Color>

    <!-- ============================================== -->
    <!-- INPUT / FORM COLORS                            -->
    <!-- ============================================== -->
    <Color x:Key="InputBackground">White</Color>
    <Color x:Key="InputBorder">#3D81A9</Color>
    <Color x:Key="InputBorderFocus">#2C6080</Color>
    <Color x:Key="InputPlaceholder">#919191</Color>
    <Color x:Key="InputText">Black</Color>

    <!-- ============================================== -->
    <!-- DIVIDERS / BORDERS                             -->
    <!-- ============================================== -->
    <Color x:Key="Divider">#BBBBBB</Color>
    <Color x:Key="DividerLight">#D8E5EE</Color>
    <Color x:Key="BorderDefault">#3D81A9</Color>

    <!-- ============================================== -->
    <!-- OVERLAYS / SHADOWS                             -->
    <!-- ============================================== -->
    <Color x:Key="OverlayScrim">#80000000</Color>
    <Color x:Key="OverlayLight">#40000000</Color>
    <Color x:Key="Shadow">#33000000</Color>
    <Color x:Key="ShadowDark">#66000000</Color>

    <!-- ============================================== -->
    <!-- SWITCH / TOGGLE COLORS                         -->
    <!-- ============================================== -->
    <Color x:Key="SwitchOnColor">#D7F2FD</Color>
    <Color x:Key="SwitchThumbColor">#3D81A9</Color>

    <!-- ============================================== -->
    <!-- PROGRESS / COMPLETION                          -->
    <!-- ============================================== -->
    <Color x:Key="ProgressBackground">#CCCCCC</Color>
    <Color x:Key="ProgressFill">#3CB371</Color>
    <Color x:Key="CompletionTick">#3CB371</Color>

    <!-- ============================================== -->
    <!-- LEGACY GRAYSCALE (for compatibility)           -->
    <!-- ============================================== -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- ============================================== -->
    <!-- BRUSHES                                        -->
    <!-- ============================================== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource Shadow}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayScrim}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

</ResourceDictionary>