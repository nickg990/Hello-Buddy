<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================== -->
    <!-- TYPOGRAPHY RESOURCE DICTIONARY                 -->
    <!-- Named styles for consistent text formatting    -->
    <!-- Uses Montserrat font family throughout         -->
    <!-- ============================================== -->

    <!-- ============================================== -->
    <!-- PAGE / HEADER STYLES                           -->
    <!-- ============================================== -->
    
    <!-- PageTitleStyle: Used in HeaderBlock for page titles -->
    <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="TextColor" Value="{StaticResource HeaderTitle}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- SubtitleStyle: Used for page subtitles (spaced letters) -->
    <Style x:Key="SubtitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="CharacterSpacing" Value="0.35" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <!-- ============================================== -->
    <!-- HEADING STYLES                                 -->
    <!-- ============================================== -->

    <!-- H1Style: Large headings within content -->
    <Style x:Key="H1Style" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- H2Style: Section headings -->
    <Style x:Key="H2Style" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- H3Style: Sub-section headings -->
    <Style x:Key="H3Style" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ============================================== -->
    <!-- BODY TEXT STYLES                               -->
    <!-- ============================================== -->

    <!-- BodyStyle: Standard body text -->
    <Style x:Key="BodyStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- BodySecondaryStyle: Secondary/muted body text -->
    <Style x:Key="BodySecondaryStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- BodyBoldStyle: Bold body text -->
    <Style x:Key="BodyBoldStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ============================================== -->
    <!-- CAPTION / SMALL TEXT STYLES                    -->
    <!-- ============================================== -->

    <!-- CaptionStyle: Small descriptive text -->
    <Style x:Key="CaptionStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- CaptionBoldStyle: Small bold text (settings labels, etc.) -->
    <Style x:Key="CaptionBoldStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ============================================== -->
    <!-- FORM / INPUT STYLES                            -->
    <!-- ============================================== -->

    <!-- FormLabelStyle: Labels for form inputs -->
    <Style x:Key="FormLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- SectionLabelStyle: Spaced-letter section headers -->
    <Style x:Key="SectionLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- ============================================== -->
    <!-- BUTTON TEXT STYLES                             -->
    <!-- ============================================== -->

    <!-- ButtonTextStyle: Standard button text -->
    <Style x:Key="ButtonTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource TextOnPrimary}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- ============================================== -->
    <!-- LINK STYLES                                    -->
    <!-- ============================================== -->

    <!-- LinkStyle: Clickable text links -->
    <Style x:Key="LinkStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextLink}" />
        <Setter Property="TextDecorations" Value="None" />
    </Style>

    <!-- ============================================== -->
    <!-- STATUS / FEEDBACK STYLES                       -->
    <!-- ============================================== -->

    <!-- ErrorTextStyle: Error messages -->
    <Style x:Key="ErrorTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Error}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- SuccessTextStyle: Success messages -->
    <Style x:Key="SuccessTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Success}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- SuccessHeadingStyle: Large success message headings -->
    <Style x:Key="SuccessHeadingStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource Success}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- ============================================== -->
    <!-- TILE / CARD STYLES                             -->
    <!-- ============================================== -->

    <!-- TileTitleStyle: Exercise tile names -->
    <Style x:Key="TileTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="MaxLines" Value="2" />
    </Style>

    <!-- ============================================== -->
    <!-- INSTRUCTION / LIST STYLES                      -->
    <!-- ============================================== -->

    <!-- InstructionNumberStyle: Step numbers in instruction lists -->
    <Style x:Key="InstructionNumberStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="VerticalOptions" Value="Start" />
    </Style>

    <!-- InstructionTextStyle: Step text in instruction lists -->
    <Style x:Key="InstructionTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <!-- ============================================== -->
    <!-- COLLAPSIBLE SECTION STYLES                     -->
    <!-- ============================================== -->

    <!-- CollapsibleHeaderStyle: Collapsible section headers -->
    <Style x:Key="CollapsibleHeaderStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- CollapsibleBodyStyle: Collapsible section body text -->
    <Style x:Key="CollapsibleBodyStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="Padding" Value="0,10,0,0" />
    </Style>

    <!-- ExpanderIconStyle: +/- icons for collapsibles -->
    <Style x:Key="ExpanderIconStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- ============================================== -->
    <!-- SPECIAL / BRANDING STYLES                      -->
    <!-- ============================================== -->

    <!-- LogoDiscTextStyle: "GETTING BETTER" text on logo disc -->
    <Style x:Key="LogoDiscTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="TextColor" Value="{StaticResource Secondary}" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- ParameterLabelStyle: "Reps:" / "Sets:" labels -->
    <Style x:Key="ParameterLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- ParameterValueStyle: Numeric values for reps/sets -->
    <Style x:Key="ParameterValueStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

</ResourceDictionary>
