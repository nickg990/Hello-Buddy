<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CaninePhysioApp.Controls"
             x:Class="CaninePhysioApp.Views.ForgottenPasswordPage"
             Shell.NavBarIsVisible="False">

    <controls:PageTemplate Title="Forgotten Password"
                           Subtitle="C     A     N     I     N     E          P     H     Y     S     I     O     T     H     E     R     A     P     Y"
                           ShowSubtitle="True">

        <!-- Slot 1: Above wave content - spacer -->
        <controls:PageTemplate.AboveWaveContent>
            <Grid HeightRequest="25" />
        </controls:PageTemplate.AboveWaveContent>

        <!-- Slot 2: Main content within the wave area -->
        <controls:PageTemplate.WaveContent>
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="{StaticResource SpacingM}">

                <!-- Row 0: Form Content - always visible -->
                <VerticalStackLayout Grid.Row="0"
                                     Spacing="{StaticResource SpacingM}">

                    <!-- Input Fields Grid - responsive layout -->
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="{StaticResource SpacingM}"
                          HorizontalOptions="Fill">

                        <!-- Email -->
                        <Label Grid.Column="0"
                               Text="Email"
                               Style="{StaticResource FormLabelStyle}" />
                        <controls:StyledInputBox Grid.Column="1"
                                                 Placeholder="Email"
                                                 Text="{Binding Email}"
                                                 Keyboard="Email"
                                                 HorizontalOptions="Fill" />
                    </Grid>

                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorTextStyle}"
                           IsVisible="{Binding HasError}" />

                    <!-- Send Reset Button -->
                    <controls:StyledButton Text="S  E  N  D     R  E  S  E  T"
                                           ButtonBackgroundColor="{StaticResource ButtonPrimary}"
                                           ButtonTextColor="{StaticResource ButtonPrimaryText}"
                                           ButtonWidth="180"
                                           HorizontalOptions="Center"
                                           Margin="0,24,0,0"
                                           Command="{Binding SendResetCommand}" />
                </VerticalStackLayout>

                <!-- Row 1: Success Message - centered -->
                <VerticalStackLayout Grid.Row="1"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     IsVisible="{Binding HasSuccess}"
                                     Spacing="{StaticResource SpacingS}">
                    <Label Text="Password reset sent!"
                           Style="{StaticResource SuccessHeadingStyle}" />
                    <Label Text="Please check your email."
                           Style="{StaticResource BodyStyle}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Row 2: Back Button - always visible at bottom -->
                <controls:StyledButton Grid.Row="2"
                                       Text="B  A  C  K"
                                       ButtonBackgroundColor="{StaticResource GhostButton}"
                                       ButtonTextColor="{StaticResource GhostButtonText}"
                                       ButtonWidth="140"
                                       ButtonHorizontalAlignment="Start"
                                       Command="{Binding NavigateBackCommand}" />

            </Grid>
        </controls:PageTemplate.WaveContent>

    </controls:PageTemplate>

</ContentPage>