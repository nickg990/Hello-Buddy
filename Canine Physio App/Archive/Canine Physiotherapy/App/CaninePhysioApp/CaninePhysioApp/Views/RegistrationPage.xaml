<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CaninePhysioApp.Controls"
             x:Class="CaninePhysioApp.Views.RegistrationPage"
             Shell.NavBarIsVisible="False">

    <controls:PageTemplate Title="Registration"
                           Subtitle="C     A     N     I     N     E          P     H     Y     S     I     O     T     H     E     R     A     P     Y"
                           ShowSubtitle="True">

        <!-- Slot 1: Above wave content - spacer -->
        <controls:PageTemplate.AboveWaveContent>
            <Grid HeightRequest="25" />
        </controls:PageTemplate.AboveWaveContent>

        <!-- Slot 2: Main content within the wave area -->
        <controls:PageTemplate.WaveContent>
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                  RowSpacing="{StaticResource SpacingM}">
                
                <!-- Row 0: Input Fields Grid - responsive layout -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="{StaticResource FormFieldSpacing}"
                      ColumnSpacing="{StaticResource SpacingM}"
                      HorizontalOptions="Fill">
                    
                    <!-- Row 0: Code -->
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Code"
                           Style="{StaticResource FormLabelStyle}" />
                    <controls:StyledInputBox Grid.Row="0" Grid.Column="1"
                                             Placeholder="Code (from email)"
                                             Text="{Binding Code}"
                                             HorizontalOptions="Fill" />
                    
                    <!-- Row 1: Email -->
                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Email"
                           Style="{StaticResource FormLabelStyle}" />
                    <controls:StyledInputBox Grid.Row="1" Grid.Column="1"
                                             Placeholder="Email"
                                             Text="{Binding Email}"
                                             Keyboard="Email"
                                             HorizontalOptions="Fill" />
                    
                    <!-- Row 2: Password -->
                    <Label Grid.Row="2" Grid.Column="0"
                           Text="Password"
                           Style="{StaticResource FormLabelStyle}" />
                    <controls:StyledInputBox Grid.Row="2" Grid.Column="1"
                                             Placeholder="Password"
                                             Text="{Binding Password}"
                                             IsPassword="True"
                                             HorizontalOptions="Fill" />
                    
                    <!-- Row 3: Confirm Password -->
                    <Label Grid.Row="3" Grid.Column="0"
                           Text="Confirm"
                           Style="{StaticResource FormLabelStyle}" />
                    <controls:StyledInputBox Grid.Row="3" Grid.Column="1"
                                             Placeholder="Confirm Password"
                                             Text="{Binding ConfirmPassword}"
                                             IsPassword="True"
                                             HorizontalOptions="Fill" />
                </Grid>

                <!-- Row 1: Message area (Error or Success) -->
                <VerticalStackLayout Grid.Row="1">
                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorTextStyle}"
                           IsVisible="{Binding HasError}" />
                    
                    <Label Text="{Binding SuccessMessage}"
                           Style="{StaticResource SuccessTextStyle}"
                           IsVisible="{Binding HasSuccess}" />
                </VerticalStackLayout>

                <!-- Row 2: Register Button -->
                <controls:StyledButton Grid.Row="2"
                                       Text="R  E  G  I  S  T  E  R"
                                       ButtonBackgroundColor="{StaticResource ButtonPrimary}"
                                       ButtonTextColor="{StaticResource ButtonPrimaryText}"
                                       ButtonWidth="165"
                                       HorizontalOptions="Center"
                                       Margin="0,24,0,0"
                                       Command="{Binding RegisterCommand}" />

                <!-- Row 3: Flexible spacer -->

                <!-- Row 4: Back Button -->
                <controls:StyledButton Grid.Row="4"
                                       Text="B  A  C  K"
                                       ButtonBackgroundColor="{StaticResource GhostButton}"
                                       ButtonTextColor="{StaticResource GhostButtonText}"
                                       ButtonWidth="140"
                                       ButtonHorizontalAlignment="Start"
                                       Command="{Binding NavigateBackCommand}" />
                
            </Grid>
        </controls:PageTemplate.WaveContent>

    </controls:PageTemplate>

</ContentPage>