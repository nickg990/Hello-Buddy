<?xml version="1.0" encoding="UTF-8" ?>
<!--
    Controls.xaml - Global Control Styles
    ======================================
    Uses Hello Buddy utility tokens: Surface, TextPrimary, TextMuted, 
    BorderDefault, DisabledSurface, DisabledText, Error.
    Light theme only (dark mode deferred).
-->
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         LABEL - Default Style
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource DisabledText}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         BUTTON - Primary Style (Base Definition)
         All button variants derive from or reference this base style.
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource TextOnPrimary}"/>
        <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySemibold}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMdInt}"/>
        <Setter Property="Padding" Value="{StaticResource SpaceButtonPadding}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
        <Setter Property="MinimumWidthRequest" Value="{StaticResource MinTapWidth}"/>
        <Setter Property="HeightRequest" Value="{StaticResource ButtonHeightDefault}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource BrandPrimaryDark}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource DisabledText}"/>
                            <Setter Property="BackgroundColor" Value="{StaticResource DisabledSurface}"/>
                            <Setter Property="BorderWidth" Value="1"/>
                            <Setter Property="BorderColor" Value="{StaticResource DisabledText}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver"/>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Button - Implicit Style (applies to all Buttons by default, inherits from ButtonPrimary) -->
    <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}" />

    <!-- Button - Secondary (Surface bg + BrandPrimary border/text) -->
    <Style x:Key="ButtonSecondary" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySemibold}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="BorderWidth" Value="{StaticResource BorderWidthDefault}"/>
        <Setter Property="BorderColor" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMdInt}"/>
        <Setter Property="Padding" Value="{StaticResource SpaceButtonPadding}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
        <Setter Property="MinimumWidthRequest" Value="{StaticResource MinTapWidth}"/>
        <Setter Property="HeightRequest" Value="{StaticResource ButtonHeightDefault}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource BrandMist}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource DisabledText}"/>
                            <Setter Property="BorderColor" Value="{StaticResource DisabledSurface}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver"/>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Button - Ghost / Text-only (no background, no border, text link appearance) -->
    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySemibold}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource SpaceButtonPadding}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
        <Setter Property="MinimumWidthRequest" Value="{StaticResource MinTapWidth}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource BrandPrimaryDark}"/>
                            <Setter Property="BackgroundColor" Value="{StaticResource BorderDefault}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource DisabledText}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver"/>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ENTRY - Default Style
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
        <Setter Property="HeightRequest" Value="{StaticResource EntryHeightDefault}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource DisabledText}"/>
                            <Setter Property="BackgroundColor" Value="{StaticResource DisabledSurface}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource White}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         EDITOR - Default Style
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource EditorMinHeight}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SWITCH - Default Style
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="ThumbColor" Value="{StaticResource White}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="{StaticResource DisabledSurface}"/>
                            <Setter Property="ThumbColor" Value="{StaticResource DisabledText}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="On">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="{StaticResource BrandPrimary}"/>
                            <Setter Property="ThumbColor" Value="{StaticResource White}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Off">
                        <VisualState.Setters>
                            <Setter Property="ThumbColor" Value="{StaticResource BrandPrimaryLight}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CHECKBOX - Default Style
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
        <Setter Property="MinimumWidthRequest" Value="{StaticResource MinTapWidth}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Color" Value="{StaticResource DisabledSurface}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         BORDER - Default Style (for cards, containers)
         Note: StrokeShape RoundRectangle values are hardcoded because MAUI does 
         not support StaticResource bindings within StrokeShape property syntax.
         These values correspond to RadiusMd (8) and RadiusLg (12) tokens.
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
        <Setter Property="Stroke" Value="{StaticResource BorderDefault}"/>
        <Setter Property="StrokeThickness" Value="{StaticResource BorderWidthDefault}"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 8,8,8,8"/>
        <Setter Property="Padding" Value="{StaticResource SpaceCardPadding}"/>
    </Style>

    <!-- Border - Card style (uses RadiusLg = 12) -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
        <Setter Property="Stroke" Value="{StaticResource BorderDefault}"/>
        <Setter Property="StrokeThickness" Value="{StaticResource BorderWidthDefault}"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 12,12,12,12"/>
        <Setter Property="Padding" Value="{StaticResource SpaceCardPadding}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FRAME - Default Style (legacy, prefer Border)
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
        <Setter Property="BorderColor" Value="{StaticResource BorderDefault}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}"/>
        <Setter Property="Padding" Value="{StaticResource SpaceCardPadding}"/>
        <Setter Property="HasShadow" Value="False"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ACTIVITY INDICATOR
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource BrandPrimary}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         PROGRESS BAR
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource BrandPrimary}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SLIDER
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="MaximumTrackColor" Value="{StaticResource BorderDefault}"/>
        <Setter Property="ThumbColor" Value="{StaticResource BrandPrimary}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         PICKER
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="TitleColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         DATE/TIME PICKERS
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SEARCH BAR
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="CancelButtonColor" Value="{StaticResource BrandPrimary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         IMAGE BUTTON
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="ImageButton">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="BorderColor" Value="Transparent"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
        <Setter Property="MinimumWidthRequest" Value="{StaticResource MinTapWidth}"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver"/>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         RADIO BUTTON
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyDefault}"/>
        <Setter Property="FontSize" Value="{StaticResource TextMd}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource MinTapHeight}"/>
        <Setter Property="MinimumWidthRequest" Value="{StaticResource MinTapWidth}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         PAGE - Default Style
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SHELL - Default Style
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Surface}"/>
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Shell.TitleColor" Value="{StaticResource BrandPrimaryDark}"/>
        <Setter Property="Shell.DisabledColor" Value="{StaticResource DisabledText}"/>
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="Shell.NavBarHasShadow" Value="False"/>
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource TabBarSurface}"/>
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextMuted}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         NAVIGATION PAGE
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Surface}"/>
        <Setter Property="BarTextColor" Value="{StaticResource BrandPrimaryDark}"/>
        <Setter Property="IconColor" Value="{StaticResource BrandPrimary}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════
         BOX VIEW (Dividers, etc.)
         ═══════════════════════════════════════════════════════════════════════ -->
    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource BorderDefault}"/>
    </Style>

    <!-- Divider style -->
    <Style x:Key="Divider" TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource BorderDefault}"/>
        <Setter Property="HeightRequest" Value="1"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
    </Style>

</ResourceDictionary>
