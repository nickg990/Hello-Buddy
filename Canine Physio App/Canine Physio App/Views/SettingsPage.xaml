<?xml version="1.0" encoding="utf-8" ?>
<!--
    SettingsPage.xaml - App Settings Page
    ======================================
    Allows users to configure app preferences including:
    - Program code display
    - Download exercise videos toggle
    - Offline caching toggle
    - Notifications toggle with time picker
    
    Layout: Uses ShowFullBody="True" mode so settings scroll
    over the hero/wave/body backgrounds as a transparent overlay.
    Buttons pinned at bottom, content scrolls above.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:layout="clr-namespace:Canine_Physio_App.Components.Layout"
             x:Class="Canine_Physio_App.Views.SettingsPage"
             Shell.NavBarIsVisible="False"
             Title="Settings"
             Padding="0"
             ios:Page.UseSafeArea="False"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls">

    <layout:AppPageTemplate
        Title="Settings"
        Subtitle="CANINE PHYSIOTHERAPY"
        ShowSubtitle="True"
        ShowHeaderIcon="False"
        ShowFullBody="True"
        ShowFooter="True"
        SecondaryButtonText="BACK"
        SecondaryCommand="{Binding NavigateBackCommand}">
        
        <!-- ═══════════════════════════════════════════════════════════════
             FULL BODY CONTENT - Grid with scrollable content and fixed buttons
             ═══════════════════════════════════════════════════════════════ -->
        <layout:AppPageTemplate.FullBodyContent>
            <VerticalStackLayout 
                Padding="{StaticResource SpacePage}"
                Spacing="{StaticResource SpaceStackLg}">
                
                        <!-- ═══════════════════════════════════════════════════════
                             PROGRAM CODE - Read-only display
                             ═══════════════════════════════════════════════════════ -->
                        <Grid ColumnDefinitions="*,Auto" BackgroundColor="Transparent">
                            <VerticalStackLayout Grid.Column="0" Spacing="{StaticResource SpaceStackXs}">
                                <Label 
                                    Text="PROGRAM CODE"
                                    Style="{StaticResource HeadingH3}"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />
                                <Label 
                                    Text="Your unique program identifier"
                                    Style="{StaticResource TextCaption}"
                                    TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <Border 
                                Grid.Column="1"
                                Stroke="{StaticResource BorderDefault}"
                                StrokeThickness="{StaticResource BorderWidthDefault}"
                                BackgroundColor="Transparent"
                                Padding="{StaticResource SpaceEntryPadding}"
                                VerticalOptions="Center">
                                <Label 
                                    Text="{Binding ProgramCode}"
                                    Style="{StaticResource TextSmStyle}"
                                    TextColor="{StaticResource TextMuted}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>
                
                        <!-- ═══════════════════════════════════════════════════════
                             DOWNLOAD EXERCISE VIDEOS Toggle
                             ═══════════════════════════════════════════════════════ -->
                        <Grid ColumnDefinitions="*,Auto" 
                              BackgroundColor="Transparent"
                              MinimumHeightRequest="{StaticResource SwitchRowHeight}">
                            <VerticalStackLayout Grid.Column="0" 
                                                 Spacing="{StaticResource SpaceStackXs}"
                                                 VerticalOptions="Center">
                                <Label 
                                    Text="DOWNLOAD EXERCISE VIDEOS"
                                    Style="{StaticResource HeadingH3}"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />
                                <Label 
                                    Text="Have access to exercise videos when you are offline"
                                    Style="{StaticResource TextCaption}"
                                    TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <Switch 
                                Grid.Column="1"
                                IsToggled="{Binding DownloadVideosEnabled}"
                                VerticalOptions="Center"
                                AutomationProperties.Name="Download exercise videos" />
                        </Grid>
                
                        <!-- ═══════════════════════════════════════════════════════
                             ENABLE OFFLINE CACHING Toggle
                             ═══════════════════════════════════════════════════════ -->
                        <Grid ColumnDefinitions="*,Auto" 
                              BackgroundColor="Transparent"
                              MinimumHeightRequest="{StaticResource SwitchRowHeight}">
                            <VerticalStackLayout Grid.Column="0" 
                                                 Spacing="{StaticResource SpaceStackXs}"
                                                 VerticalOptions="Center">
                                <Label 
                                    Text="ENABLE OFFLINE CACHING"
                                    Style="{StaticResource HeadingH3}"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />
                                <Label 
                                    Text="Download exercise data for offline use"
                                    Style="{StaticResource TextCaption}"
                                    TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <Switch 
                                Grid.Column="1"
                                IsToggled="{Binding OfflineCachingEnabled}"
                                VerticalOptions="Center"
                                AutomationProperties.Name="Enable offline caching" />
                        </Grid>
                
                        <!-- ═══════════════════════════════════════════════════════
                             NOTIFICATIONS Toggle
                             ═══════════════════════════════════════════════════════ -->
                        <Grid ColumnDefinitions="*,Auto" 
                              BackgroundColor="Transparent"
                              MinimumHeightRequest="{StaticResource SwitchRowHeight}">
                            <VerticalStackLayout Grid.Column="0" 
                                                 Spacing="{StaticResource SpaceStackXs}"
                                                 VerticalOptions="Center">
                                <Label 
                                    Text="NOTIFICATIONS"
                                    Style="{StaticResource HeadingH3}"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />
                                <Label 
                                    Text="Receive reminders for your exercises"
                                    Style="{StaticResource TextCaption}"
                                    TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <Switch 
                                Grid.Column="1"
                                IsToggled="{Binding NotificationsEnabled}"
                                VerticalOptions="Center"
                                AutomationProperties.Name="Notifications" />
                        </Grid>
                
                        <!-- ═══════════════════════════════════════════════════════
                             NOTIFICATION TIME Picker (visible when notifications enabled)
                             ═══════════════════════════════════════════════════════ -->
                        <Grid ColumnDefinitions="*,Auto" 
                              BackgroundColor="Transparent"
                              MinimumHeightRequest="{StaticResource SwitchRowHeight}"
                              IsVisible="{Binding NotificationsEnabled}">
                            <VerticalStackLayout Grid.Column="0" 
                                                 Spacing="{StaticResource SpaceStackXs}"
                                                 VerticalOptions="Center">
                                <Label 
                                    Text="NOTIFICATION TIME"
                                    Style="{StaticResource HeadingH3}"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />
                                <Label 
                                    Text="Choose when to receive daily reminders"
                                    Style="{StaticResource TextCaption}"
                                    TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <TimePicker 
                                Grid.Column="1"
                                Time="{Binding NotificationTime}"
                                Format="HH:mm"
                                TextColor="{StaticResource TextPrimary}"
                                FontSize="{StaticResource TextMd}"
                                VerticalOptions="Center"
                                AutomationProperties.Name="Notification time" />
                        </Grid>
                    
                </VerticalStackLayout>
        </layout:AppPageTemplate.FullBodyContent>
        
    </layout:AppPageTemplate>

</ContentPage>
