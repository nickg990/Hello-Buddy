<?xml version="1.0" encoding="utf-8" ?>
<!--
    ForgottenPasswordPage.xaml - Password Reset Request Page
    =========================================================
    Allows users to request a password reset by entering their email address.
    Shows success message after submission, hiding the form.
    
    Layout: Non-scrollable page using AppPageTemplate (matches archive design).
    - Hero: Email entry (75% width), Error message, SEND RESET button, Success message
    - Body: Empty (all content in hero/wave area per archive)
    - Footer: BACK button (ghost style, left-aligned)
    
    Entry field uses BrandMist background with BrandPrimary border to match hero area.
    Form hides and success message shows after successful submission.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:layout="clr-namespace:Canine_Physio_App.Components.Layout"
             x:Class="Canine_Physio_App.Views.ForgottenPasswordPage"
             Shell.NavBarIsVisible="False"
             Title="Forgotten Password"
             Padding="0"
             ios:Page.UseSafeArea="False"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls">

    <layout:AppPageTemplate
        Title="Forgotten Password"
        Subtitle="CANINE PHYSIOTHERAPY"
        ShowSubtitle="True"
        ShowHeaderIcon="False"
        IsBodyScrollable="True"
        ShowOverlay="{Binding IsLoading}"
        ShowFooter="True"
        SecondaryButtonText="BACK"
        SecondaryCommand="{Binding NavigateBackCommand}">
        
        <!-- ═══════════════════════════════════════════════════════════════
             HERO CONTENT - Form (hides on success) and Success message
             Entry is 75% screen width using Grid column ratios (*,6*,*).
             Matches archive layout: form + button in wave area.
             ═══════════════════════════════════════════════════════════════ -->
        <layout:AppPageTemplate.HeroContent>
            <Grid VerticalOptions="Fill">
                
                <!-- Form Content - visible until success -->
                <VerticalStackLayout 
                    Spacing="{StaticResource SpaceStackMd}"
                    VerticalOptions="Center"
                    IsVisible="{Binding IsNotSubmitted}">
                    
                    <!-- Email Entry - 75% width via Grid columns (*,6*,*) -->
                    <Grid ColumnDefinitions="*,6*,*">
                        <VerticalStackLayout 
                            Grid.Column="1" 
                            Spacing="{StaticResource SpaceStackXs}">
                            <Label 
                                Text="Email"
                                Style="{StaticResource TextSmStyle}"
                                TextColor="{StaticResource TextPrimary}" />
                            <Border 
                                Stroke="{StaticResource BrandPrimary}"
                                StrokeThickness="{StaticResource BorderWidthDefault}"
                                BackgroundColor="{StaticResource BrandMist}"
                                Padding="{StaticResource SpaceEntryPadding}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="{StaticResource CornerRadiusMd}" />
                                </Border.StrokeShape>
                                <Entry 
                                    Text="{Binding Email}"
                                    Placeholder="Enter your email"
                                    Keyboard="Email"
                                    ReturnType="Done"
                                    BackgroundColor="Transparent"
                                    AutomationProperties.Name="Email" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                    
                    <!-- Error Message Area - Fixed height to prevent layout shift -->
                    <Grid HeightRequest="{StaticResource Space24}">
                        <Label 
                            Text="{Binding ErrorMessage}"
                            Style="{StaticResource TextSmStyle}"
                            TextColor="{StaticResource ErrorOnMist}"
                            HorizontalTextAlignment="Center"
                            VerticalOptions="Center"
                            IsVisible="{Binding HasError}" />
                    </Grid>
                    
                    <!-- Send Reset Button -->
                    <Button 
                        Text="SEND RESET"
                        Style="{StaticResource ButtonPrimary}"
                        HorizontalOptions="Center"
                        WidthRequest="{StaticResource AuthButtonWidth}"
                        Command="{Binding SendResetCommand}"
                        AutomationProperties.Name="Send reset" />
                    
                </VerticalStackLayout>
                
                <!-- Success Message - visible after success -->
                <VerticalStackLayout
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="{StaticResource SpaceStackSm}"
                    IsVisible="{Binding IsSubmitted}">
                    <Label 
                        Text="Password reset sent!"
                        Style="{StaticResource HeadingH3}"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalTextAlignment="Center" />
                    <Label 
                        Text="Please check your email."
                        Style="{StaticResource TextMdStyle}"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                
            </Grid>
        </layout:AppPageTemplate.HeroContent>
        
        <!-- ═══════════════════════════════════════════════════════════════
             BODY CONTENT - Empty (all content in hero per archive design)
             ═══════════════════════════════════════════════════════════════ -->
        <layout:AppPageTemplate.BodyContent>
            <Grid />
        </layout:AppPageTemplate.BodyContent>
        
    </layout:AppPageTemplate>
    
</ContentPage>
