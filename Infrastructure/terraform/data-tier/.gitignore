# Secrets — never commit these
terraform.tfvars
*.auto.tfvars

# Terraform state and lock files — keep state remote or local-only
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Terraform working directory
.terraform/

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
