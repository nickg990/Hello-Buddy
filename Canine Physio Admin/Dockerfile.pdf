# syntax=docker/dockerfile:1.7
# PDF service image — PuppeteerSharp + Chromium. Same pattern as the
# Day 3 admin Dockerfile so cold-start does not trigger a Chromium download.

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY Directory.Build.props Directory.Packages.props ./
COPY src/HelloBuddy.Contracts/HelloBuddy.Contracts.csproj         src/HelloBuddy.Contracts/
COPY src/HelloBuddy.Admin.Pdf/HelloBuddy.Admin.Pdf.csproj         src/HelloBuddy.Admin.Pdf/
COPY src/HelloBuddy.PdfService/HelloBuddy.PdfService.csproj       src/HelloBuddy.PdfService/
RUN dotnet restore src/HelloBuddy.PdfService/HelloBuddy.PdfService.csproj

COPY src/ src/
RUN dotnet publish src/HelloBuddy.PdfService/HelloBuddy.PdfService.csproj \
    -c Release \
    -o /app/publish \
    --no-restore \
    /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app

ENV DEBIAN_FRONTEND=noninteractive

# Pin Chromium to 149.0.7827.114-1~deb12u1 — the version confirmed working on 2026-06-18.
# snapshot.debian.org freezes the apt repo at that date, preventing silent apt-drift to a
# newer Chromium that introduces a hard dbus dependency and crashes in a minimal container.
RUN rm -f /etc/apt/sources.list.d/debian.sources \
    && echo 'deb [check-valid-until=no] https://snapshot.debian.org/archive/debian/20260618T000000Z/ bookworm main' > /etc/apt/sources.list \
    && echo 'deb [check-valid-until=no] https://snapshot.debian.org/archive/debian-security/20260618T000000Z/ bookworm-security main' >> /etc/apt/sources.list \
    && apt-get -o Acquire::Check-Valid-Until=false update \
    && apt-get install -y --no-install-recommends \
    "chromium=149.0.7827.114-1~deb12u1" \
    ca-certificates \
    fonts-liberation \
    fonts-dejavu-core \
    libnss3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libx11-xcb1 \
    && rm -rf /var/lib/apt/lists/*

ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium \
    ASPNETCORE_URLS=http://+:8080 \
    DOTNET_RUNNING_IN_CONTAINER=true

COPY --from=build /app/publish ./

EXPOSE 8080
ENTRYPOINT ["dotnet", "HelloBuddy.PdfService.dll"]
