@using HelloBuddy.Contracts
@inherits RazorEngineCore.RazorEngineTemplateBase<ProgrammeVm>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>@Model.ProgrammeName &mdash; @Model.PetName</title>
<style>
/* PDF-S4: small top/bottom margin on EVERY page (incl. continuation pages);
   left/right 0 to preserve the header band's horizontal full-bleed (horizontal
   insets come from .content and .pdf-header padding).
   PRECEDENCE NOTE: the PDF service passes PuppeteerSharp PdfOptions.MarginOptions
   (12 mm all round in PuppeteerPdfRenderer.cs), but a CSS @@page margin takes
   precedence over MarginOptions for the page box in Chromium print. The effective
   margin is therefore this CSS 10 mm, NOT the C# value — the C# margins appear
   inert by design. Margin lives here (API-rendered template), not in the PDF
   service, per the agreed CSS-only decision (see DecisionLog). */
@@page { size: A4; margin: 10mm 0; }
/* ── Body ──────────────────────────────────────────────────────────────── */
body { font-family: Georgia, Cambria, 'Times New Roman', serif; color: #223843; margin: 0; padding: 0; font-size: 10.5pt; line-height: 1.5; }
/* ── Header band (dark #28404F) ──────────────────────────────────────── */
/* PDF-S4: negative top margin pulls the page-1 header up into the 10 mm @@page
   top margin so it stays full-bleed to the very top edge, while pages 2+ (which
   have no header) still get the uniform 10 mm top margin. */
.pdf-header { background: #28404F; padding: 10mm 14mm; margin-top: -10mm; display: flex; align-items: center; gap: 14px; }
/* Logo sized to match the header text block height (title 17pt + 2 sub-lines 9pt each). */
.pdf-header-logo { width: 68px; height: 68px; flex-shrink: 0; }
.pdf-header-body { flex: 1; }
.pdf-header-title { color: #fff; font-size: 17pt; font-weight: 700; margin: 0 0 1px 0; line-height: 1.2; }
.pdf-header-sub { color: #D9E7EC; font-size: 9pt; margin: 0; line-height: 1.6; }
/* ── Content wrapper ─────────────────────────────────────────────────── */
.content { padding: 0 12mm 10mm 12mm; }
/* ── Summary band (#D9E7EC) ──────────────────────────────────────────── */
.summary-band { background: #D9E7EC; border: 1px solid #B9CBD4; margin: 6mm 0 5mm 0; padding: 5mm 6mm; border-radius: 2px; }
.summary-title { font-size: 16pt; font-weight: 700; color: #223843; margin: 0 0 3px 0; }
.summary-meta { color: #223843; font-size: 9.5pt; margin: 2px 0; }
.summary-muted { color: #5A6E7A; font-size: 9pt; margin: 2px 0; }
/* ── Session ─────────────────────────────────────────────────────────── */
/* ERR-AT-013: removed break-inside:avoid from .session so AM and PM sessions
   flow continuously rather than forcing a whole session onto a new page.
   break-after:avoid on the heading prevents orphan section titles at page bottom.
   break-inside:avoid is retained on .ex-row so individual exercise rows do not split.
   PDF-S3: both modern (break-inside) and legacy (page-break-inside) properties are
   required — headless-shell Chromium print mode honours the legacy property more
   reliably. Both must be present on .ex-row and its inner blocks to keep the whole
   exercise unit (media + info + instructions) together across page boundaries. */
.session { margin-bottom: 6mm; }
.session-heading { background: #D9E7EC; border: 1px solid #B9CBD4; border-radius: 2px 2px 0 0; padding: 3mm 5mm; break-after: avoid; }
.session-heading h2 { font-size: 12pt; font-weight: 700; color: #223843; margin: 0; }
.session-objective { font-size: 9pt; color: #5A6E7A; background: #F8FBFC; border-left: 1px solid #B9CBD4; border-right: 1px solid #B9CBD4; padding: 2mm 5mm; }
/* ── Exercise rows ───────────────────────────────────────────────────── */
.ex-row { background: #F8FBFC; border: 1px solid #B9CBD4; border-top: 0; padding: 4mm 5mm; break-inside: avoid; page-break-inside: avoid; }
.ex-row:last-child { border-radius: 0 0 2px 2px; }
.ex-row-top { display: flex; gap: 10px; align-items: flex-start; break-inside: avoid; page-break-inside: avoid; }
.ex-media { width: 76px; height: 76px; flex: 0 0 76px; border: 1px solid #6392AE; border-radius: 2px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #D4E0E5; }
.ex-media img { max-width: 100%; max-height: 100%; object-fit: cover; }
.ex-media-link { color: #245E7C; font-size: 8pt; text-align: center; text-decoration: underline; padding: 4px; }
.ex-media-empty { color: #5A6E7A; font-size: 8pt; text-align: center; padding: 4px; }
.ex-info { flex: 1; min-width: 0; }
.ex-title { font-weight: 700; font-size: 11pt; color: #223843; margin: 0 0 2px 0; }
.ex-prescription { font-size: 9.5pt; color: #223843; margin: 0 0 2px 0; }
.ex-obj { color: #5A6E7A; font-size: 9pt; margin: 0; }
/* ── Exercise instructions ────────────────────────────────────────────── */
.ex-instructions { margin: 3mm 0 0 0; padding-left: 5mm; font-size: 9.5pt; color: #223843; line-height: 1.5; break-inside: avoid; page-break-inside: avoid; }
.ex-instructions li { margin-bottom: 1mm; }
/* ── Footer ──────────────────────────────────────────────────────────── */
.pdf-footer { color: #5A6E7A; font-size: 8pt; margin-top: 8mm; text-align: center; border-top: 1px solid #B9CBD4; padding-top: 3mm; }
.pdf-disclaimer { max-width: 189mm; margin: 4mm auto 0 auto; text-align: justify; line-height: 1.5; }
</style>
</head>
<body>

<div class="pdf-header">
  <img src="__LOGO_DATA_URI__" alt="Hello Buddy" class="pdf-header-logo" />
  <div class="pdf-header-body">
    <p class="pdf-header-title">Canine Physiotherapy</p>
    <p class="pdf-header-sub">Home exercise programme</p>
    <p class="pdf-header-sub">Prepared for @Model.PetName &middot; @Model.OwnerName</p>
  </div>
</div>

<div class="content">

<div class="summary-band">
  <p class="summary-title">@Model.ProgrammeName</p>
  <p class="summary-meta">@Model.CaseTitle &middot; @Model.Status &middot; @Model.StartDate.ToString("d MMMM yyyy")@(Model.EndDate.HasValue ? " to " + Model.EndDate.Value.ToString("d MMMM yyyy") : "")</p>
  <p class="summary-muted">Pet: @Model.PetName &middot; Owner: @Model.OwnerName</p>
</div>

@foreach (var session in Model.Sessions)
{
<div class="session">
  <div class="session-heading"><h2>@(string.IsNullOrEmpty(session.Period) ? session.Period : char.ToUpperInvariant(session.Period[0]) + session.Period.Substring(1))</h2></div>
@if (!string.IsNullOrWhiteSpace(session.Objective))
{
  <div class="session-objective">@session.Objective</div>
}
@foreach (var ex in session.Exercises)
{
  <div class="ex-row">
    <div class="ex-row-top">
      <div class="ex-media">
@if (!string.IsNullOrWhiteSpace(ex.ImageUrl) && !string.IsNullOrWhiteSpace(ex.VideoUrl))
{
  @* target="_blank" hints the PDF viewer to open the video in a new tab.
     PDF link behaviour varies by browser/viewer; this is the best-supported approach
     available in PuppeteerSharp-generated PDFs. Some viewers may ignore the attribute. *@
<a href="@ex.VideoUrl" target="_blank"><img src="@ex.ImageUrl" alt="@ex.ExerciseTitle image" /></a>
}
else if (!string.IsNullOrWhiteSpace(ex.ImageUrl))
{
<img src="@ex.ImageUrl" alt="@ex.ExerciseTitle image" />
}
else if (!string.IsNullOrWhiteSpace(ex.VideoUrl))
{
  @* target="_blank" hints the PDF viewer to open the video in a new tab. *@
<a class="ex-media-link" href="@ex.VideoUrl" target="_blank">Video</a>
}
else
{
<span class="ex-media-empty">No image</span>
}
      </div>
      <div class="ex-info">
        <p class="ex-title">@ex.ExerciseTitle</p>
        <p class="ex-prescription">@(ex.Reps?.ToString() ?? "&mdash;") reps &middot; @(ex.Sets?.ToString() ?? "&mdash;") sets@(ex.HoldSeconds.HasValue ? " &middot; " + ex.HoldSeconds.Value + "s hold" : "")@if (!string.IsNullOrEmpty(ex.Notes)) {<text> &middot; @(ex.Notes!.Length > 60 ? ex.Notes.Substring(0, 60) + "\u2026" : ex.Notes)</text>}</p>
@if (!string.IsNullOrWhiteSpace(ex.ObjectiveSummary))
{
        <p class="ex-obj">@ex.ObjectiveSummary</p>
}
      </div>
    </div>
@if (ex.Instructions != null && ex.Instructions.Count > 0)
{
    <ol class="ex-instructions">
@foreach (var step in ex.Instructions)
{
        <li>@step.InstructionText</li>
}
    </ol>
}
  </div>
}
</div>
}

<div class="pdf-footer">
  Generated @DateTime.Now.ToString("yyyy-MM-dd HH:mm") &middot; @Model.PractitionerName
  @if (!string.IsNullOrWhiteSpace(Model.DisclaimerText))
  {
  <div class="pdf-disclaimer">@Model.DisclaimerText</div>
  }
</div>

</div>
</body>
</html>
