@using HelloBuddy.Contracts
@inherits RazorEngineCore.RazorEngineTemplateBase<ProgrammeVm>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>@Model.ProgrammeName &mdash; @Model.PetName</title>
<style>
@@page { size: A4; margin: 0; }
body { font-family: 'Segoe UI', Arial, sans-serif; color: #222; margin: 0; padding: 0; font-size: 11pt; line-height: 1.4; }
.container { padding: 0 4mm; }
h1 { margin: 0 0 4px 0; font-size: 20pt; }
h2 { margin: 16px 0 4px 0; font-size: 14pt; border-bottom: 1px solid #ccc; padding-bottom: 2px; }
.subhead { color: #666; margin-bottom: 12px; }
.meta { display: flex; gap: 24px; margin-bottom: 12px; }
.meta div { flex: 1; }
table { width: 100%; border-collapse: collapse; margin-top: 4px; }
th, td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #eee; vertical-align: top; }
th { background: #f4f4f4; font-weight: 600; font-size: 10pt; }
.ex-title { font-weight: 600; }
.ex-obj { color: #666; font-size: 10pt; }
.ex-cell { display: flex; gap: 8px; align-items: flex-start; }
.ex-media { width: 70px; height: 70px; flex: 0 0 70px; border: 1px solid #ddd; border-radius: 4px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #f8f8f8; }
.ex-media img { max-width: 100%; max-height: 100%; }
.ex-media-link, .ex-media-empty { color: #888; font-size: 8pt; text-align: center; text-decoration: none; }
.ex-info { flex: 1; }
.session { break-inside: avoid; margin-bottom: 12px; }
.footer { color: #888; font-size: 9pt; margin-top: 24px; text-align: center; }
.col-exercise-wide { width: 40%; }
.col-reps { width: 10%; }
.col-sets { width: 10%; }
.col-hold { width: 12%; }
</style>
</head>
<body>
<div class="container">
<h1>@Model.ProgrammeName</h1>
<div class="subhead">@Model.CaseTitle &middot; Programme #@Model.ProgrammeId &middot; @Model.Status</div>
<div class="meta">
<div><strong>Pet:</strong> @Model.PetName</div>
<div><strong>Owner:</strong> @Model.OwnerName</div>
<div><strong>Starts:</strong> @Model.StartDate.ToString("yyyy-MM-dd")@(Model.EndDate.HasValue ? " – " + Model.EndDate.Value.ToString("yyyy-MM-dd") : "")</div>
</div>
@if (!string.IsNullOrWhiteSpace(Model.Notes))
{
<p><strong>Notes:</strong> @Model.Notes</p>
}
@foreach (var session in Model.Sessions)
{
<div class="session">
<h2>Session @session.SortOrder &mdash; @session.Period</h2>
@if (!string.IsNullOrWhiteSpace(session.Objective))
{
<div class="subhead">@session.Objective</div>
}
<table>
<thead>
<tr>
<th class="col-exercise-wide">Exercise</th>
<th class="col-reps">Reps</th>
<th class="col-sets">Sets</th>
<th class="col-hold">Hold (s)</th>
<th>Notes</th>
</tr>
</thead>
<tbody>
@foreach (var ex in session.Exercises)
{
<tr>
<td>
<div class="ex-cell">
<div class="ex-media">
@if (!string.IsNullOrWhiteSpace(ex.ImageUrl) && !string.IsNullOrWhiteSpace(ex.VideoUrl))
{
<a href="@ex.VideoUrl"><img src="@ex.ImageUrl" alt="@ex.ExerciseTitle image" /></a>
}
else if (!string.IsNullOrWhiteSpace(ex.ImageUrl))
{
<img src="@ex.ImageUrl" alt="@ex.ExerciseTitle image" />
}
else if (!string.IsNullOrWhiteSpace(ex.VideoUrl))
{
<a class="ex-media-link" href="@ex.VideoUrl">Video</a>
}
else
{
<span class="ex-media-empty">No image</span>
}
</div>
<div class="ex-info">
<div class="ex-title">@ex.ExerciseTitle</div>
@if (!string.IsNullOrWhiteSpace(ex.ObjectiveSummary))
{
<div class="ex-obj">@ex.ObjectiveSummary</div>
}
</div>
</div>
</td>
<td>@(ex.Reps?.ToString() ?? "—")</td>
<td>@(ex.Sets?.ToString() ?? "—")</td>
<td>@(ex.HoldSeconds?.ToString() ?? "—")</td>
<td>@(ex.Notes ?? "")</td>
</tr>
}
</tbody>
</table>
</div>
}
<div class="footer">Generated @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm 'UTC'") &middot; Hello Buddy Cloud Admin</div>
</div>
</body>
</html>
