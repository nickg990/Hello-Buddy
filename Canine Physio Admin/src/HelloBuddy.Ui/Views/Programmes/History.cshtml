@model ProgrammeVersionHistoryVm
@{
    ViewData["Title"] = "PDF History";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>PDF History</h2>
        <p class="text-muted mb-1">
            <a asp-controller="Owners" asp-action="Details" asp-route-id="@Model.OwnerId">@Model.OwnerName</a>
            <span> . </span>
            <a asp-controller="Pets" asp-action="Details" asp-route-id="@Model.PetId">@Model.PetName</a>
            <span> . </span>
            <a asp-controller="CaseDetail" asp-action="Index" asp-route-id="@Model.TreatmentCaseId">@Model.CaseTitle</a>
            <span> . </span>
            <a asp-action="Builder" asp-route-id="@Model.ProgrammeId">@Model.ProgrammeName</a>
            <span> . </span>
            <span>PDF History</span>
        </p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="CaseDetail" asp-action="Index" asp-route-id="@Model.TreatmentCaseId">&larr; Back to treatment case</a>
</div>

@if (Model.Versions.Count == 0)
{
    <div class="alert alert-info">No version records exist yet for this programme.</div>
}
else
{
    <div class="d-grid gap-3">
        @foreach (var v in Model.Versions)
        {
            <article class="card" aria-label="Version @v.VersionNumber">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h2 class="h5 mb-0">Version @v.VersionNumber</h2>
                        <span class="badge text-bg-secondary">@v.VersionStatus</span>
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-sm-3">Created</dt>
                        <dd class="col-sm-9">@v.CreatedDate.ToString("yyyy-MM-dd HH:mm")</dd>

                        <dt class="col-sm-3">Published</dt>
                        <dd class="col-sm-9">@(v.PublishedDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>

                        <dt class="col-sm-3">Superseded</dt>
                        <dd class="col-sm-9">@(v.SupersededDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>

                        <dt class="col-sm-3">Author</dt>
                        <dd class="col-sm-9">@v.CreatedByPractitionerName</dd>

                        <dt class="col-sm-3">Summary</dt>
                        <dd class="col-sm-9 mb-0">@(string.IsNullOrWhiteSpace(v.ChangeSummary) ? "-" : v.ChangeSummary)</dd>
                    </dl>

                    <div class="mt-3 d-flex gap-2">
                        @if (v.PublishedDate.HasValue)
                        {
                            <a class="btn btn-outline-secondary btn-sm"
                               href="@Url.Action("ViewVersionPdf", "Programmes", new { id = Model.ProgrammeId, versionId = v.ProgrammeVersionId })"
                               title="View PDF for this version" target="_blank">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                    <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/>
                                    <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                                </svg>
                                View
                            </a>
                        }
                        <form id="delete-version-form-@v.ProgrammeVersionId"
                              method="post"
                              asp-action="DeleteVersion"
                              asp-route-id="@Model.ProgrammeId"
                              asp-route-versionId="@v.ProgrammeVersionId"
                              class="d-none">
                            @Html.AntiForgeryToken()
                        </form>
                        <button type="button" class="btn btn-outline-danger btn-sm" title="Delete this version"
                                data-bs-toggle="modal" data-bs-target="#deleteVersionModal"
                                data-confirm-form-id="delete-version-form-@v.ProgrammeVersionId"
                                data-version-number="@v.VersionNumber">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0A.5.5 0 0 1 8.5 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1 0-2H5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1h2.5a1 1 0 0 1 1 1ZM6 2v.5h4V2H6ZM4 4v9a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4H4Z"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </article>
        }
    </div>
}
<div class="modal fade" id="deleteVersionModal" tabindex="-1" aria-labelledby="deleteVersionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteVersionModalLabel">Delete version record?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete <strong id="delete-version-label"></strong>?</p>
                <p class="mb-0"><strong>This action cannot be undone.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="delete-version-confirm-btn">Delete version</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var modal = document.getElementById('deleteVersionModal');
            var confirmBtn = document.getElementById('delete-version-confirm-btn');
            if (!modal || !confirmBtn) return;
            var pendingFormId;
            modal.addEventListener('show.bs.modal', function (e) {
                pendingFormId = e.relatedTarget && e.relatedTarget.dataset.confirmFormId;
                var labelEl = document.getElementById('delete-version-label');
                if (labelEl) {
                    var vNum = e.relatedTarget && e.relatedTarget.dataset.versionNumber;
                    labelEl.textContent = vNum ? 'version ' + vNum : 'this version record';
                }
            });
            confirmBtn.addEventListener('click', function () {
                if (pendingFormId) document.getElementById(pendingFormId).submit();
            });
        })();
    </script>
}