@model HelloBuddy.Ui.Models.ProgrammesBuilderPageVm
@{
    var programme = Model.Programme;
    ViewData["Title"] = $"PDF Builder: {programme.ProgrammeName}";
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const root = document.getElementById('builder-root');
            if (!root) {
                return;
            }

            const editorPanelUrl = root.dataset.editorPanelUrl;
            const feedback = document.getElementById('builder-feedback');

            const hasChanged = (input) => {
                if (input.type === 'radio' || input.type === 'checkbox') {
                    const initialChecked = input.dataset.initialChecked === 'True' || input.dataset.initialChecked === 'true';
                    return input.checked !== initialChecked;
                }

                const initial = input.dataset.initialValue ?? '';
                return (input.value ?? '') !== initial;
            };

            const updateSaveState = (controls, button) => {
                if (!button || !controls) {
                    return;
                }

                const changed = Array.from(controls).some(hasChanged);
                button.disabled = !changed;
            };

            const renderFeedback = (kind, text) => {
                if (!text) {
                    return;
                }

                if (typeof window.showToast === 'function') {
                    window.showToast(text, kind === 'error' ? 'error' : 'success');
                    return;
                }

                if (feedback) {
                    const alertClass = kind === 'error' ? 'alert-danger' : 'alert-success';
                    feedback.innerHTML = '<div class="alert ' + alertClass + ' mb-3" role="status">' + text + '</div>';
                }
            };

            const bindChangeState = () => {
                const setupForm = document.getElementById('setup-form');
                const saveSetupButton = document.getElementById('save-setup');
                const sessionControls = document.querySelectorAll('[form="session-edits-form"]');
                const saveSessionButton = document.getElementById('save-session-edits');

                if (setupForm) {
                    const setupControls = setupForm.querySelectorAll('input, select, textarea');
                    setupForm.addEventListener('input', function () {
                        updateSaveState(setupControls, saveSetupButton);
                    });
                    setupForm.addEventListener('change', function () {
                        updateSaveState(setupControls, saveSetupButton);
                    });
                    updateSaveState(setupControls, saveSetupButton);
                }

                sessionControls.forEach(function (input) {
                    input.addEventListener('input', function () {
                        updateSaveState(sessionControls, saveSessionButton);
                    });
                    input.addEventListener('change', function () {
                        updateSaveState(sessionControls, saveSessionButton);
                    });
                });
                updateSaveState(sessionControls, saveSessionButton);
            };

            const refreshPanels = async () => {
                const editorHost = document.getElementById('builder-editor-container');
                if (!editorHost) {
                    return;
                }

                const currentScroll = window.scrollY;
                const editorResponse = await fetch(editorPanelUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });

                if (!editorResponse.ok) {
                    throw new Error('Failed to refresh builder panel.');
                }

                editorHost.innerHTML = await editorResponse.text();
                bindChangeState();
                bindAsyncForms();
                window.scrollTo({ top: currentScroll, behavior: 'auto' });
            };

            const bindAsyncForms = () => {
                const forms = root.querySelectorAll('form[data-async-builder="true"]');
                forms.forEach(function (form) {
                    if (form.dataset.asyncBound === 'true') {
                        return;
                    }

                    form.dataset.asyncBound = 'true';
                    form.addEventListener('submit', async function (event) {
                        event.preventDefault();

                        const submitter = event.submitter;
                        const originalText = submitter ? submitter.textContent : null;
                        if (submitter) {
                            submitter.disabled = true;
                            submitter.textContent = 'Saving...';
                        }

                        try {
                            const formData = new FormData(form);
                            const response = await fetch(form.action, {
                                method: form.method || 'POST',
                                body: formData,
                                headers: {
                                    'X-Requested-With': 'XMLHttpRequest'
                                }
                            });

                            if (!response.ok) {
                                throw new Error('Request failed.');
                            }

                            const payload = await response.json();
                            if (!payload.ok) {
                                renderFeedback('error', payload.error || 'Unable to update programme builder.');
                                return;
                            }

                            await refreshPanels();
                            renderFeedback('success', payload.message || 'Programme builder updated.');
                        } catch (error) {
                            renderFeedback('error', 'Unable to update programme builder. Please retry.');
                        } finally {
                            if (submitter) {
                                submitter.disabled = false;
                                submitter.textContent = originalText;
                            }
                        }
                    });
                });
            };

            bindChangeState();
            bindAsyncForms();
        })();
    </script>
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>Exercise Programme Builder</h2>
        <p class="text-muted mb-1">
            <a asp-controller="Owners" asp-action="Details" asp-route-id="@programme.OwnerId">@programme.OwnerName</a>
            <span> . </span>
            <a asp-controller="Pets" asp-action="Details" asp-route-id="@programme.PetId">@programme.PetName</a>
            <span> . </span>
            <a asp-controller="CaseDetail" asp-action="Index" asp-route-id="@programme.TreatmentCaseId">@programme.CaseTitle</a>
            <span> . </span>
            <span>@programme.ProgrammeName</span>
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap justify-content-end">
        <a class="btn btn-outline-secondary" asp-controller="CaseDetail" asp-action="Index" asp-route-id="@programme.TreatmentCaseId">&larr; Back to treatment case</a>
        <a class="btn btn-outline-secondary" asp-action="Preview" asp-route-id="@programme.ProgrammeId">PDF Viewer</a>
        <a class="btn btn-outline-secondary" asp-action="History" asp-route-id="@programme.ProgrammeId">PDF History</a>
    </div>
</div>

<div id="builder-feedback"></div>

<div id="builder-root"
     data-editor-panel-url="@Url.Action("BuilderEditorPanel", "Programmes", new { id = programme.ProgrammeId })"
     class="row g-3 align-items-start">
    <div class="col-12" id="builder-editor-container">
        <partial name="_BuilderEditor" model="Model" />
    </div>
</div>

