@model HelloBuddy.Ui.Models.ProgrammesBuilderPageVm
@{
    var programme = Model.Programme;
    ViewData["Title"] = $"Builder: {programme.ProgrammeName}";
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const root = document.getElementById('builder-root');
            if (!root) {
                return;
            }

            const editorPanelUrl = root.dataset.editorPanelUrl;
            const previewPanelUrl = root.dataset.previewPanelUrl;
            const feedback = document.getElementById('builder-feedback');
            let previewSyncTimer = null;

            const hasChanged = (input) => {
                if (input.type === 'radio' || input.type === 'checkbox') {
                    const initialChecked = input.dataset.initialChecked === 'True' || input.dataset.initialChecked === 'true';
                    return input.checked !== initialChecked;
                }

                const initial = input.dataset.initialValue ?? '';
                return (input.value ?? '') !== initial;
            };

            const updateSaveState = (controls, button) => {
                if (!button || !controls) {
                    return;
                }

                const changed = Array.from(controls).some(hasChanged);
                button.disabled = !changed;
            };

            const renderFeedback = (kind, text) => {
                if (!feedback) {
                    return;
                }

                if (!text) {
                    feedback.innerHTML = '';
                    return;
                }

                const alertClass = kind === 'error' ? 'alert-danger' : 'alert-success';
                feedback.innerHTML = '<div class="alert ' + alertClass + ' mb-3" role="status">' + text + '</div>';
            };

            const bindChangeState = () => {
                const setupForm = document.getElementById('setup-form');
                const saveSetupButton = document.getElementById('save-setup');
                const sessionControls = document.querySelectorAll('[form="session-edits-form"]');
                const saveSessionButton = document.getElementById('save-session-edits');

                const schedulePreviewSync = () => {
                    if (previewSyncTimer) {
                        clearTimeout(previewSyncTimer);
                    }

                    previewSyncTimer = setTimeout(syncPreviewFromInputs, 250);
                };

                if (setupForm) {
                    const setupControls = setupForm.querySelectorAll('input, select, textarea');
                    setupForm.addEventListener('input', function () {
                        updateSaveState(setupControls, saveSetupButton);
                        schedulePreviewSync();
                    });
                    setupForm.addEventListener('change', function () {
                        updateSaveState(setupControls, saveSetupButton);
                        schedulePreviewSync();
                    });
                    updateSaveState(setupControls, saveSetupButton);
                }

                sessionControls.forEach(function (input) {
                    input.addEventListener('input', function () {
                        updateSaveState(sessionControls, saveSessionButton);
                        schedulePreviewSync();
                    });
                    input.addEventListener('change', function () {
                        updateSaveState(sessionControls, saveSessionButton);
                        schedulePreviewSync();
                    });
                });
                updateSaveState(sessionControls, saveSessionButton);
            };

            const setText = (selector, value) => {
                const element = document.querySelector(selector);
                if (element) {
                    element.textContent = value;
                }
            };

            const syncPreviewFromInputs = () => {
                const programmeNameInput = document.querySelector('[data-preview-field="programmeName"]');
                const startDateInput = document.querySelector('[data-preview-field="startDate"]');
                const endDateInput = document.querySelector('[data-preview-field="endDate"]');

                if (programmeNameInput) {
                    const value = (programmeNameInput.value || '').trim();
                    setText('#preview-programme-name', value.length > 0 ? value : 'Untitled programme');
                }

                if (startDateInput) {
                    setText('#preview-start-date', startDateInput.value || '-');
                }

                if (endDateInput) {
                    const value = endDateInput.value || '';
                    setText('#preview-end-date', value);
                    const separator = document.getElementById('preview-date-separator');
                    if (separator) {
                        separator.classList.toggle('d-none', value.length === 0);
                    }
                }

                const mappedFields = ['reps', 'sets', 'holdSeconds', 'notes'];
                mappedFields.forEach(function (fieldName) {
                    const controls = document.querySelectorAll('[data-preview-field="' + fieldName + '"][data-session-exercise-id]');
                    controls.forEach(function (control) {
                        const sessionExerciseId = control.dataset.sessionExerciseId;
                        if (!sessionExerciseId) {
                            return;
                        }

                        const row = document.querySelector('[data-preview-session-exercise-id="' + sessionExerciseId + '"]');
                        if (!row) {
                            return;
                        }

                        const target = row.querySelector('[data-preview-field="' + fieldName + '"]');
                        if (!target) {
                            return;
                        }

                        const raw = (control.value || '').trim();
                        target.textContent = raw.length > 0 ? raw : '-';
                    });
                });
            };

            const refreshPanels = async () => {
                const editorHost = document.getElementById('builder-editor-container');
                const previewHost = document.getElementById('builder-preview-container');
                if (!editorHost || !previewHost) {
                    return;
                }

                const currentScroll = window.scrollY;
                const [editorResponse, previewResponse] = await Promise.all([
                    fetch(editorPanelUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } }),
                    fetch(previewPanelUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                ]);

                if (!editorResponse.ok || !previewResponse.ok) {
                    throw new Error('Failed to refresh builder panels.');
                }

                editorHost.innerHTML = await editorResponse.text();
                previewHost.innerHTML = await previewResponse.text();
                bindChangeState();
                bindAsyncForms();
                syncPreviewFromInputs();
                window.scrollTo({ top: currentScroll, behavior: 'auto' });
            };

            const bindAsyncForms = () => {
                const forms = root.querySelectorAll('form[data-async-builder="true"]');
                forms.forEach(function (form) {
                    if (form.dataset.asyncBound === 'true') {
                        return;
                    }

                    form.dataset.asyncBound = 'true';
                    form.addEventListener('submit', async function (event) {
                        event.preventDefault();

                        const submitter = event.submitter;
                        const originalText = submitter ? submitter.textContent : null;
                        if (submitter) {
                            submitter.disabled = true;
                            submitter.textContent = 'Saving...';
                        }

                        try {
                            const formData = new FormData(form);
                            const response = await fetch(form.action, {
                                method: form.method || 'POST',
                                body: formData,
                                headers: {
                                    'X-Requested-With': 'XMLHttpRequest'
                                }
                            });

                            if (!response.ok) {
                                throw new Error('Request failed.');
                            }

                            const payload = await response.json();
                            if (!payload.ok) {
                                renderFeedback('error', payload.error || 'Unable to update programme builder.');
                                return;
                            }

                            await refreshPanels();
                            renderFeedback('success', payload.message || 'Programme builder updated.');
                        } catch (error) {
                            renderFeedback('error', 'Unable to update programme builder. Please retry.');
                        } finally {
                            if (submitter) {
                                submitter.disabled = false;
                                submitter.textContent = originalText;
                            }
                        }
                    });
                });
            };

            bindChangeState();
            bindAsyncForms();
            syncPreviewFromInputs();
        })();
    </script>
}

<p><a asp-controller="CaseDetail" asp-action="Index" asp-route-id="@programme.TreatmentCaseId">&larr; Back to case</a></p>

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@programme.ProgrammeName</h1>
        <p class="text-muted mb-0">Programme #@programme.ProgrammeId · @programme.CaseTitle · @programme.PetName (@programme.OwnerName)</p>
    </div>
    <div>
        <form method="post" asp-action="Publish" asp-route-id="@programme.ProgrammeId" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Publish PDF</button>
        </form>
    </div>
</div>

<div id="builder-feedback"></div>

<div id="builder-root"
     data-editor-panel-url="@Url.Action("BuilderEditorPanel", "Programmes", new { id = programme.ProgrammeId })"
     data-preview-panel-url="@Url.Action("BuilderPreviewPanel", "Programmes", new { id = programme.ProgrammeId })"
     class="row g-3 align-items-start">
    <div class="col-12 col-xxl-7" id="builder-editor-container">
        <partial name="_BuilderEditor" model="Model" />
    </div>
    <div class="col-12 col-xxl-5" id="builder-preview-container">
        <partial name="_BuilderPreviewPane" model="Model.Programme" />
    </div>
</div>
