<!DOCTYPE html>
<html lang="en-GB">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] - HelloBuddy.Ui</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HelloBuddy.Ui.styles.css" asp-append-version="true" />
</head>

<body>
    <a class="visually-hidden-focusable bg-dark text-white p-2" href="#main-content">Skip to main content</a>
    <header class="site-header">
        <nav class="navbar site-navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand p-0" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo-disc.svg" alt="Hello Buddy" class="brand-logo" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                                     <a class="nav-link text-dark" asp-area="" asp-controller="Owners"
                                         asp-action="Index">Owners</a>
                                </li>
                                <li class="nav-item">
                                     <a class="nav-link text-dark" asp-area="" asp-controller="Pets"
                                         asp-action="Index">Pets</a>
                                </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Exercises"
                               asp-action="Index">Exercise library</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home"
                               asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main id="main-content" role="main" class="pb-3" tabindex="-1">
            @{
                var toastSaved = TempData["Saved"] as string;
                var toastError = TempData["Error"] as string;
                var toastPublished = TempData["Published"] as string;
                var toastPublishedFile = TempData["PublishedFile"] as string;
            }
            <div class="toast-container app-toast-container position-fixed top-0 end-0 p-3" aria-live="polite" aria-atomic="true">
                @if (!string.IsNullOrEmpty(toastSaved))
                {
                    <div class="toast text-bg-success border-0 app-toast" role="status" aria-live="polite" aria-atomic="true" data-bs-delay="5000">
                        <div class="d-flex">
                            <div class="toast-body">@toastSaved</div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(toastPublished))
                {
                    <div class="toast text-bg-success border-0 app-toast" role="status" aria-live="polite" aria-atomic="true" data-bs-delay="8000">
                        <div class="d-flex">
                            <div class="toast-body">
                                @toastPublished
                                @if (!string.IsNullOrEmpty(toastPublishedFile))
                                {
                                    <a class="alert-link ms-1" asp-controller="Programmes" asp-action="Download"
                                       asp-route-fileName="@toastPublishedFile" target="_blank" rel="noopener">Download PDF</a>
                                }
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(toastError))
                {
                    <div class="toast text-bg-danger border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="8000">
                        <div class="d-flex">
                            <div class="toast-body">@toastError</div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                }
            </div>
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 Net Intentions Ltd
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
