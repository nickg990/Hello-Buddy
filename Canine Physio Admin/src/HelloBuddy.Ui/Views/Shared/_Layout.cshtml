<!DOCTYPE html>
<html lang="en-GB">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] - HelloBuddy.Ui</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HelloBuddy.Ui.styles.css" asp-append-version="true" />
</head>

<body>
    <a class="visually-hidden-focusable bg-dark text-white p-2" href="#main-content">Skip to main content</a>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">HelloBuddy.Ui</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                                     <a class="nav-link text-dark" asp-area="" asp-controller="Owners"
                                         asp-action="Index">Owners</a>
                                </li>
                                <li class="nav-item">
                                     <a class="nav-link text-dark" asp-area="" asp-controller="Pets"
                                         asp-action="Index">Pets</a>
                                </li>
                                <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Cases"
                               asp-action="Index">Cases</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Exercises"
                               asp-action="Index">Exercise library</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home"
                               asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main id="main-content" role="main" class="pb-3" tabindex="-1">
            <div aria-live="polite" aria-atomic="true">
                @if (TempData["Saved"] is string layoutSaved)
                {
                    <div class="alert alert-success">@layoutSaved</div>
                }
                @if (TempData["Published"] is string layoutPublished)
                {
                    <div class="alert alert-success" role="alert">
                        @layoutPublished
                        @if (TempData["PublishedFile"] is string publishedFile)
                        {
                            <a class="alert-link ms-2" asp-controller="Programmes" asp-action="Download"
                               asp-route-fileName="@publishedFile" target="_blank" rel="noopener">Download PDF</a>
                        }
                    </div>
                }
                @if (TempData["Error"] is string layoutError)
                {
                    <div class="alert alert-danger" role="alert">@layoutError</div>
                }
            </div>
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - HelloBuddy.Ui - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
