@model IReadOnlyList<PetListItem>
@{
    ViewData["Title"] = "Pets";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>Pets</h2>
        <p class="text-muted mb-1">All registered pets</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add pet</a>
</div>

@if (TempData["Saved"] is string saved)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @saved
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-info">No pets have been added yet.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Owner</th>
                <th>Breed</th>
                <th>Status</th>
                <th>Cases</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pet in Model)
            {
                <tr>
                    <td>@pet.Name</td>
                    <td>@pet.OwnerName</td>
                    <td>@(pet.Breed ?? "-")</td>
                    <td>@(pet.IsActive ? "Active" : "Inactive")</td>
                    <td>@pet.CaseCount</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Details" asp-route-id="@pet.PetId">Open</a>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger delete-pet-btn"
                                data-pet-id="@pet.PetId"
                                data-pet-name="@pet.Name"
                                data-owner-name="@pet.OwnerName"
                                data-bs-toggle="modal"
                                data-bs-target="#deletePetModal"
                                title="Delete pet">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                            </svg>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="modal fade" id="deletePetModal" tabindex="-1" aria-labelledby="deletePetModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deletePetModalLabel">Delete pet?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete <strong id="deletePetName"></strong> (owner: <span id="deletePetOwnerName"></span>)?</p>
                <div class="alert alert-warning mb-0" role="alert">
                    <strong>Warning: this action is irreversible.</strong>
                    This will permanently delete the pet and all their associated case notes, treatment cases, exercise programmes, sessions, and any stored programme PDFs. The owner record will be preserved.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deletePetForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete pet</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('.delete-pet-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = btn.getAttribute('data-pet-id');
                    var name = btn.getAttribute('data-pet-name');
                    var ownerName = btn.getAttribute('data-owner-name');
                    document.getElementById('deletePetName').textContent = name;
                    document.getElementById('deletePetOwnerName').textContent = ownerName;
                    document.getElementById('deletePetForm').action = '/Pets/' + id + '/Delete';
                });
            });
        })();
    </script>
}