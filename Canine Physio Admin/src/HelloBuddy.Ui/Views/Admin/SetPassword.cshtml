@model SetPasswordViewModel

@{
    ViewData["Title"] = "Set Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-3">
                <a class="btn btn-outline-secondary" asp-action="Practitioners">&larr; Back to practitioners</a>
            </div>
            <h2 class="mb-4">Set Password</h2>
            <p class="text-muted">Practitioner: <strong>@Model.PractitionerName</strong></p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    @Html.ValidationSummary(excludePropertyErrors: false)
                </div>
            }

            <form method="post" asp-action="SetPassword" class="needs-validation">
                <input type="hidden" name="PractitionerId" value="@Model.PractitionerId" />

                <div class="mb-3">
                    <label for="NewPassword" class="form-label">New Password <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" id="NewPassword" name="NewPassword" required />
                </div>

                <div class="mb-3">
                    <label for="ConfirmPassword" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                    <input type="password" class="form-control" id="ConfirmPassword" name="ConfirmPassword" required />
                </div>

                <div class="mb-4">
                    <button type="submit" class="btn btn-primary">Set Password</button>
                    <a href="@Url.Action("Practitioners", "Admin")" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

