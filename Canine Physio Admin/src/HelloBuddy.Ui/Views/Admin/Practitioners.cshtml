@using HelloBuddy.Application.Auth
@model List<PractitionerSummary>

@{
    ViewData["Title"] = "Manage Practitioners";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Practitioners</h2>
        <a href="@Url.Action("Add", "Admin")" class="btn btn-primary">+ Add Practitioner</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No practitioners found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var practitioner in Model)
                    {
                        <tr>
                            <td>@practitioner.FirstName @practitioner.LastName</td>
                            <td>@practitioner.Email</td>
                            <td>@practitioner.PhoneNumber</td>
                            <td><span class="badge bg-info">@practitioner.Role</span></td>
                            <td>
                                @if (practitioner.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Edit", "Admin", new { id = practitioner.PractitionerId })" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a href="@Url.Action("SetPassword", "Admin", new { id = practitioner.PractitionerId })" class="btn btn-sm btn-outline-warning">Set Password</a>

                                @if (practitioner.IsActive)
                                {
                                    <form id="deactivate-form-@practitioner.PractitionerId" method="post" asp-action="Delete" asp-route-id="@practitioner.PractitionerId" class="d-none">
                                        @Html.AntiForgeryToken()
                                    </form>
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal" data-bs-target="#deactivatePractitionerModal"
                                            data-confirm-form-id="deactivate-form-@practitioner.PractitionerId"
                                            data-practitioner-name="@practitioner.FirstName @practitioner.LastName">Deactivate</button>
                                }
                                else
                                {
                                    <form id="activate-form-@practitioner.PractitionerId" method="post" asp-action="Activate" asp-route-id="@practitioner.PractitionerId" class="d-none">
                                        @Html.AntiForgeryToken()
                                    </form>
                                    <button type="button" class="btn btn-sm btn-outline-success"
                                            data-bs-toggle="modal" data-bs-target="#activatePractitionerModal"
                                            data-confirm-form-id="activate-form-@practitioner.PractitionerId"
                                            data-practitioner-name="@practitioner.FirstName @practitioner.LastName">Activate</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

<div class="modal fade" id="deactivatePractitionerModal" tabindex="-1" aria-labelledby="deactivatePractitionerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deactivatePractitionerModalLabel">Deactivate practitioner?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to deactivate <strong id="deactivate-practitioner-name"></strong>?</p>
                <p class="mb-0">They will no longer be able to log in. You can re-activate them at any time.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="deactivate-confirm-btn">Deactivate</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="activatePractitionerModal" tabindex="-1" aria-labelledby="activatePractitionerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="activatePractitionerModalLabel">Re-activate practitioner?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Re-activate <strong id="activate-practitioner-name"></strong>? They will be able to log in again.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="activate-confirm-btn">Re-activate</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var deactivateModal = document.getElementById('deactivatePractitionerModal');
            var deactivateConfirmBtn = document.getElementById('deactivate-confirm-btn');
            if (deactivateModal && deactivateConfirmBtn) {
                var pendingFormId;
                deactivateModal.addEventListener('show.bs.modal', function (e) {
                    pendingFormId = e.relatedTarget && e.relatedTarget.dataset.confirmFormId;
                    var nameEl = document.getElementById('deactivate-practitioner-name');
                    if (nameEl) nameEl.textContent = (e.relatedTarget && e.relatedTarget.dataset.practitionerName) || '';
                });
                deactivateConfirmBtn.addEventListener('click', function () {
                    if (pendingFormId) document.getElementById(pendingFormId).submit();
                });
            }
            var activateModal = document.getElementById('activatePractitionerModal');
            var activateConfirmBtn = document.getElementById('activate-confirm-btn');
            if (activateModal && activateConfirmBtn) {
                var pendingActivateFormId;
                activateModal.addEventListener('show.bs.modal', function (e) {
                    pendingActivateFormId = e.relatedTarget && e.relatedTarget.dataset.confirmFormId;
                    var nameEl = document.getElementById('activate-practitioner-name');
                    if (nameEl) nameEl.textContent = (e.relatedTarget && e.relatedTarget.dataset.practitionerName) || '';
                });
                activateConfirmBtn.addEventListener('click', function () {
                    if (pendingActivateFormId) document.getElementById(pendingActivateFormId).submit();
                });
            }
        })();
    </script>
}
