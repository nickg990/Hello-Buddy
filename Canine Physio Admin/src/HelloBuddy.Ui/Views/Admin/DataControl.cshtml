@model AdminOwnerDataControlViewModel

@{
    ViewData["Title"] = "GDPR Data Control";
}

<div class="container mt-5">
    <div class="mb-4">
        <h2>GDPR Data Control (RTBF)</h2>
    </div>

    <div class="card border-danger">
        <div class="card-body">
            <h3 class="h5 text-danger">Right To Be Forgotten</h3>
            <p class="mb-2">
                Apply owner GDPR deletion. The owner and associated records, including stored programme PDFs, are permanently deleted.
            </p>
            <div class="alert alert-warning" role="alert">
                Warning: this action is irreversible.
            </div>

            <form id="rtbf-form" method="post" asp-action="DataControl">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="row g-3 align-items-end">
                    <div class="col-sm-8 col-md-6 col-lg-5">
                        <label class="form-label" for="OwnerId">Owner</label>
                        <select class="form-select" id="OwnerId" name="OwnerId" required>
                            <option value="">Select owner...</option>
                            @foreach (var owner in Model.Owners)
                            {
                                var isSelected = Model.OwnerId.HasValue && Model.OwnerId.Value == owner.OwnerId;
                                <option value="@owner.OwnerId" selected="@isSelected">@owner.FullName (@owner.Email)</option>
                            }
                        </select>
                        <span class="text-danger" asp-validation-for="OwnerId"></span>
                    </div>

                    <div class="col-sm-auto">
                        <button type="button" class="btn btn-danger"
                                data-bs-toggle="modal" data-bs-target="#rtbfConfirmModal">Apply RTBF</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="rtbfConfirmModal" tabindex="-1" aria-labelledby="rtbfConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="rtbfConfirmModalLabel">Apply GDPR data control?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Apply right-to-be-forgotten data control for the selected owner?</p>
                <p class="mb-0"><strong>Important:</strong> This will permanently delete the owner and all associated records, including stored programme PDFs. This action cannot be reversed.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="rtbf-confirm-btn">Apply RTBF</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var confirmBtn = document.getElementById('rtbf-confirm-btn');
            var form = document.getElementById('rtbf-form');
            if (confirmBtn && form) {
                confirmBtn.addEventListener('click', function () {
                    form.submit();
                });
            }
        })();
    </script>
}