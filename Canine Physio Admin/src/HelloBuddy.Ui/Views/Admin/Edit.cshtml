@model RenamePractitionerViewModel

@{
    ViewData["Title"] = "Edit Practitioner";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">Edit Practitioner</h2>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    @Html.ValidationSummary(excludePropertyErrors: false)
                </div>
            }

            <form method="post" asp-action="Edit" class="needs-validation">
                <input type="hidden" name="PractitionerId" value="@Model.PractitionerId" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="FirstName" class="form-label">First Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="FirstName" name="FirstName" value="@Model.FirstName" required />
                    </div>
                    <div class="col-md-6">
                        <label for="LastName" class="form-label">Last Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="LastName" name="LastName" value="@Model.LastName" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                    <input type="email" class="form-control" id="Email" name="Email" value="@Model.Email" required />
                </div>

                <div class="mb-3">
                    <label for="Phone" class="form-label">Phone</label>
                    <input type="tel" class="form-control" id="Phone" name="Phone" value="@Model.Phone" />
                </div>

                <div class="mb-4">
                    <button type="submit" class="btn btn-primary">Update Practitioner</button>
                    <a href="@Url.Action("Practitioners", "Admin")" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

