@model CaseDetailPageVm
@{
    ViewData["Title"] = $"Case: {Model.Case.CaseTitle}";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>Treatment Case</h2>
        <p class="text-muted mb-1">
            <a asp-controller="Owners" asp-action="Details" asp-route-id="@Model.Case.OwnerId">@Model.Case.OwnerName</a>
            <span> . </span>
            <a asp-controller="Pets" asp-action="Details" asp-route-id="@Model.Case.PetId">@Model.Case.PetName</a>
            <span> . </span>
            <span>@Model.Case.CaseTitle</span>
        </p>
        <p class="text-muted mb-0"><strong>@Model.Case.Status</strong> ·
            @Model.Case.StartDate.ToString("yyyy-MM-dd")@(Model.Case.EndDate is { } end ? " – " + end.ToString("yyyy-MM-dd") : "") · @Model.Case.PractitionerName</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Pets" asp-action="Details" asp-route-id="@Model.Case.PetId">&larr; Back to pet</a>
        <a class="btn btn-outline-secondary" asp-controller="Cases" asp-action="Edit" asp-route-id="@Model.Case.TreatmentCaseId">Edit case</a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Patient</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8"><a asp-controller="Pets" asp-action="Details" asp-route-id="@Model.Case.PetId">@Model.Case.PetName</a></dd>
                    <dt class="col-sm-4">Breed</dt>
                    <dd class="col-sm-8">@(Model.Case.PetBreed ?? "—")</dd>
                    <dt class="col-sm-4">Sex</dt>
                    <dd class="col-sm-8">@(Model.Case.PetSex ?? "—")</dd>
                    <dt class="col-sm-4">Weight</dt>
                    <dd class="col-sm-8">@(Model.Case.PetWeight is { } w ? $"{w:0.0} kg" : "—")</dd>
                    <dt class="col-sm-4">Age</dt>
                    <dd class="col-sm-8">@(Model.Case.PetAge is { } a ? a.ToString() : "—")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Owner</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Case.OwnerName</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Case.OwnerEmail</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Case.ClinicalSummary))
{
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h4">Clinical summary</h2>
            <p class="mb-0">@Model.Case.ClinicalSummary</p>
        </div>
    </div>
}

<div id="caseDetailBody" data-case-content-url="/Cases/@Model.Case.TreatmentCaseId/ContentPanel">
    <partial name="_CaseDetailBody" model="Model" />
</div>

<div class="modal fade" id="deleteNoteModal" tabindex="-1" aria-labelledby="deleteNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteNoteModalLabel">Delete case note?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this case note?</p>
                <p class="mb-0"><strong>This action cannot be undone.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="delete-note-confirm-btn">Delete note</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteProgrammeModal" tabindex="-1" aria-labelledby="deleteProgrammeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteProgrammeModalLabel">Delete programme?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this programme?</p>
                <p class="mb-0"><strong>This action cannot be undone.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="delete-programme-confirm-btn">Delete programme</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editNoteModal" tabindex="-1" aria-labelledby="editNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form id="editNoteForm" method="post" data-async-case>
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="editNoteModalLabel">Edit case note</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label" for="editNoteType">Note type</label>
                        <input type="text" class="form-control" id="editNoteType" name="NoteType" maxlength="50" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="editNoteText">Note</label>
                        <textarea class="form-control" id="editNoteText" name="NoteText" rows="4" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var body = document.getElementById('caseDetailBody');
            if (!body) { return; }
            var contentUrl = body.getAttribute('data-case-content-url');
            var caseId = '@Model.Case.TreatmentCaseId';

            function toast(message, kind) {
                if (window.showToast) { window.showToast(message, kind || 'success'); }
            }

            // Re-fetch just the case-detail body partial and swap it in place, preserving scroll.
            function refreshBody() {
                var scrollY = window.scrollY;
                return fetch(contentUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (r) { return r.text(); })
                    .then(function (html) {
                        body.innerHTML = html;
                        window.scrollTo(0, scrollY);
                        bindEditNoteButtons();
                    });
            }

            // Submit an async case form via fetch; on success refresh the body in place.
            function submitAsyncForm(form) {
                var scrollY = window.scrollY;
                var fd = new FormData(form);
                var method = (form.getAttribute('method') || 'post').toUpperCase();
                fetch(form.action, {
                    method: method,
                    body: fd,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(function (r) {
                        if (!r.ok) { throw new Error('Request failed'); }
                        return r.json();
                    })
                    .then(function (data) {
                        window.scrollTo(0, scrollY);
                        if (data && data.ok === false) {
                            toast(data.error || data.message || 'Action failed.', 'error');
                            return;
                        }
                        if (form.hasAttribute('data-reset-on-success')) {
                            form.reset();
                        }
                        var msg = (data && (data.message || data.error)) || 'Saved.';
                        return refreshBody().then(function () { toast(msg, 'success'); });
                    })
                    .catch(function () {
                        window.scrollTo(0, scrollY);
                        toast('Something went wrong. Please try again.', 'error');
                    });
            }

            // Delegated submit handler: intercept any async case form (content is swapped dynamically).
            document.addEventListener('submit', function (e) {
                var form = e.target;
                if (form && form.matches && form.matches('form[data-async-case]')) {
                    e.preventDefault();
                    submitAsyncForm(form);
                }
            });

            // Delete note confirm modal
            var deleteNoteModal = document.getElementById('deleteNoteModal');
            var deleteNoteConfirmBtn = document.getElementById('delete-note-confirm-btn');
            if (deleteNoteModal && deleteNoteConfirmBtn) {
                var pendingNoteFormId;
                deleteNoteModal.addEventListener('show.bs.modal', function (e) {
                    pendingNoteFormId = e.relatedTarget && e.relatedTarget.dataset.confirmFormId;
                });
                deleteNoteConfirmBtn.addEventListener('click', function () {
                    if (pendingNoteFormId) {
                        var f = document.getElementById(pendingNoteFormId);
                        window.bootstrap.Modal.getOrCreateInstance(deleteNoteModal).hide();
                        if (f) { submitAsyncForm(f); }
                    }
                });
            }

            // Delete programme confirm modal
            var deleteProgrammeModal = document.getElementById('deleteProgrammeModal');
            var deleteProgrammeConfirmBtn = document.getElementById('delete-programme-confirm-btn');
            if (deleteProgrammeModal && deleteProgrammeConfirmBtn) {
                var pendingProgrammeFormId;
                deleteProgrammeModal.addEventListener('show.bs.modal', function (e) {
                    pendingProgrammeFormId = e.relatedTarget && e.relatedTarget.dataset.confirmFormId;
                });
                deleteProgrammeConfirmBtn.addEventListener('click', function () {
                    if (pendingProgrammeFormId) {
                        var f = document.getElementById(pendingProgrammeFormId);
                        window.bootstrap.Modal.getOrCreateInstance(deleteProgrammeModal).hide();
                        if (f) { submitAsyncForm(f); }
                    }
                });
            }

            // Edit note modal populate + submit
            var editModalEl = document.getElementById('editNoteModal');
            var editModal = editModalEl && window.bootstrap
                ? window.bootstrap.Modal.getOrCreateInstance(editModalEl)
                : null;
            var editForm = document.getElementById('editNoteForm');
            var editType = document.getElementById('editNoteType');
            var editText = document.getElementById('editNoteText');

            function bindEditNoteButtons() {
                document.querySelectorAll('[data-edit-note]').forEach(function (btn) {
                    if (btn.dataset.bound === '1') { return; }
                    btn.dataset.bound = '1';
                    btn.addEventListener('click', function () {
                        var noteId = btn.getAttribute('data-note-id');
                        if (editType) { editType.value = btn.getAttribute('data-note-type') || ''; }
                        if (editText) { editText.value = btn.getAttribute('data-note-text') || ''; }
                        if (editForm) { editForm.action = '/Cases/' + caseId + '/Notes/' + noteId + '/Update'; }
                        if (editModal) { editModal.show(); }
                    });
                });
            }

            // Hide the edit modal after a successful async submit of the edit form.
            if (editForm) {
                editForm.addEventListener('submit', function () {
                    if (editModal) { editModal.hide(); }
                });
            }

            bindEditNoteButtons();
        })();
    </script>
}
