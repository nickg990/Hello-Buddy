@model CaseDetailPageVm
@{
    ViewData["Title"] = $"Case: {Model.Case.CaseTitle}";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>Treatment Case</h2>
        <p class="text-muted mb-1">
            <a asp-controller="Owners" asp-action="Details" asp-route-id="@Model.Case.OwnerId">@Model.Case.OwnerName</a>
            <span> . </span>
            <a asp-controller="Pets" asp-action="Details" asp-route-id="@Model.Case.PetId">@Model.Case.PetName</a>
            <span> . </span>
            <span>@Model.Case.CaseTitle</span>
        </p>
        <p class="text-muted mb-0"><strong>@Model.Case.Status</strong> ·
            @Model.Case.StartDate.ToString("yyyy-MM-dd")@(Model.Case.EndDate is { } end ? " – " + end.ToString("yyyy-MM-dd") : "")</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Pets" asp-action="Details" asp-route-id="@Model.Case.PetId">&larr; Back to pet</a>
        <a class="btn btn-outline-secondary" asp-controller="Cases" asp-action="Edit" asp-route-id="@Model.Case.TreatmentCaseId">Edit case</a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Patient</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8"><a asp-controller="Pets" asp-action="Details" asp-route-id="@Model.Case.PetId">@Model.Case.PetName</a></dd>
                    <dt class="col-sm-4">Breed</dt>
                    <dd class="col-sm-8">@(Model.Case.PetBreed ?? "—")</dd>
                    <dt class="col-sm-4">Sex</dt>
                    <dd class="col-sm-8">@(Model.Case.PetSex ?? "—")</dd>
                    <dt class="col-sm-4">Weight</dt>
                    <dd class="col-sm-8">@(Model.Case.PetWeight is { } w ? $"{w:0.0} kg" : "—")</dd>
                    <dt class="col-sm-4">Age</dt>
                    <dd class="col-sm-8">@(Model.Case.PetAge is { } a ? a.ToString() : "—")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Owner</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Case.OwnerName</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Case.OwnerEmail</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Case.ClinicalSummary))
{
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h4">Clinical summary</h2>
            <p class="mb-0">@Model.Case.ClinicalSummary</p>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Case notes</h2>
                @if (Model.Case.Notes.Count == 0)
                {
                    <div class="alert alert-info mb-0">No case notes recorded yet.</div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var note in Model.Case.Notes)
                        {
                            var noteTypeLabel = string.IsNullOrWhiteSpace(note.NoteType) ? "Clinical note" : note.NoteType;
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <strong>@noteTypeLabel</strong>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-muted">@note.CreatedDate.ToString("yyyy-MM-dd HH:mm")</span>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                title="Edit note"
                                                aria-label="Edit note"
                                                data-edit-note
                                                data-note-id="@note.TreatmentCaseNoteId"
                                                data-note-type="@note.NoteType"
                                                data-note-text="@note.NoteText">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
                                            </svg>
                                        </button>
                                        <form id="delete-note-form-@note.TreatmentCaseNoteId"
                                              asp-action="DeleteNote"
                                              asp-route-id="@Model.Case.TreatmentCaseId"
                                              asp-route-noteId="@note.TreatmentCaseNoteId"
                                              method="post"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="Delete note"
                                                    aria-label="Delete note"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteNoteModal"
                                                    data-confirm-form-id="delete-note-form-@note.TreatmentCaseNoteId">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0A.5.5 0 0 1 8.5 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z" />
                                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1 0-2H5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1h2.5a1 1 0 0 1 1 1ZM6 2v.5h4V2H6ZM4 4v9a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4H4Z" />
                                                </svg>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                <p class="mb-0 mt-2">@note.NoteText</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Add case note</h2>
                <form asp-action="Notes" asp-route-id="@Model.Case.TreatmentCaseId" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="NewNote.NoteType" class="form-label"></label>
                        <input asp-for="NewNote.NoteType" class="form-control" />
                        <span asp-validation-for="NewNote.NoteType" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewNote.NoteText" class="form-label"></label>
                        <textarea asp-for="NewNote.NoteText" class="form-control" rows="6"></textarea>
                        <span asp-validation-for="NewNote.NoteText" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Add note</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2 class="h4 mb-0">Programmes</h2>
        <p class="text-muted mb-0">Create a programme for this case or open an existing PDF Builder.</p>
    </div>
    <form asp-action="CreateProgramme" asp-route-id="@Model.Case.TreatmentCaseId" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary">New programme</button>
    </form>
</div>

@if (Model.Case.Programmes.Count == 0)
{
    <div class="alert alert-info">No programmes on this case yet.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Sessions</th>
                        <th>Exercises</th>
                        <th>Start</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Case.Programmes.OrderBy(p => p.StartDate))
                    {
                        var status = p.Status?.Trim().ToLowerInvariant() ?? string.Empty;
                        var statusFormId = $"programme-status-{p.ProgrammeId}";
                        var statusOptions = status switch
                        {
                            "planned" => new[] { "planned", "active" },
                            "active" => new[] { "active", "completed" },
                            "completed" => new[] { "completed" },
                            _ => new[] { status },
                        };
                        <tr>
                            <td>@p.ProgrammeName</td>
                            <td>
                                <select name="targetStatus"
                                        class="form-select form-select-sm"
                                        form="@statusFormId"
                                        aria-label="Programme status">
                                    @foreach (var option in statusOptions)
                                    {
                                        var isSelected = string.Equals(option, status, StringComparison.OrdinalIgnoreCase);
                                        var optionLabel = string.IsNullOrWhiteSpace(option)
                                            ? "Unknown"
                                            : char.ToUpperInvariant(option[0]) + option[1..];
                                        <option value="@option" selected="@isSelected">@optionLabel</option>
                                    }
                                </select>
                            </td>
                            <td>@p.SessionCount</td>
                            <td>@p.ExerciseCount</td>
                            <td>@p.StartDate.ToString("yyyy-MM-dd")</td>
                            <td class="text-end d-flex justify-content-end gap-2">
                                <form id="@statusFormId"
                                      asp-action="UpdateProgrammeStatus"
                                      asp-route-id="@Model.Case.TreatmentCaseId"
                                      asp-route-programmeId="@p.ProgrammeId"
                                      method="post"
                                      class="d-none">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="currentStatus" value="@status" />
                                </form>
                                <button type="submit" form="@statusFormId" class="btn btn-sm btn-outline-secondary">Apply</button>
                                @if (p.IsLockedForEdit)
                                {
                                    <span class="btn btn-sm btn-outline-secondary disabled"
                                          aria-disabled="true"
                                          title="Published programmes are locked. Create a new draft from PDF History to edit.">
                                        PDF Builder
                                    </span>
                                }
                                else
                                {
                                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Programmes" asp-action="Builder"
                                       asp-route-id="@p.ProgrammeId">PDF Builder</a>
                                }
                                <a class="btn btn-sm btn-outline-secondary" asp-controller="Programmes" asp-action="Preview"
                                              asp-route-id="@p.ProgrammeId">PDF Viewer</a>
                                          <a class="btn btn-sm btn-outline-secondary" asp-controller="Programmes" asp-action="History"
                                              asp-route-id="@p.ProgrammeId">PDF History</a>
                                <form id="delete-programme-form-@p.ProgrammeId"
                                      asp-action="DeleteProgramme"
                                      asp-route-id="@Model.Case.TreatmentCaseId"
                                      asp-route-programmeId="@p.ProgrammeId"
                                      method="post"
                                      class="d-none">
                                    @Html.AntiForgeryToken()
                                </form>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        aria-label="Delete programme @p.ProgrammeName"
                                        title="Delete programme"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteProgrammeModal"
                                        data-confirm-form-id="delete-programme-form-@p.ProgrammeId"
                                        data-programme-name="@p.ProgrammeName">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0A.5.5 0 0 1 8.5 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z" />
                                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1 0-2H5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1h2.5a1 1 0 0 1 1 1ZM6 2v.5h4V2H6ZM4 4v9a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4H4Z" />
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="modal fade" id="deleteNoteModal" tabindex="-1" aria-labelledby="deleteNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteNoteModalLabel">Delete case note?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this case note?</p>
                <p class="mb-0"><strong>This action cannot be undone.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="delete-note-confirm-btn">Delete note</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteProgrammeModal" tabindex="-1" aria-labelledby="deleteProgrammeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteProgrammeModalLabel">Delete programme?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this programme?</p>
                <p class="mb-0"><strong>This action cannot be undone.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="delete-programme-confirm-btn">Delete programme</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editNoteModal" tabindex="-1" aria-labelledby="editNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form id="editNoteForm" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="editNoteModalLabel">Edit case note</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label" for="editNoteType">Note type</label>
                        <input type="text" class="form-control" id="editNoteType" name="NoteType" maxlength="50" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="editNoteText">Note</label>
                        <textarea class="form-control" id="editNoteText" name="NoteText" rows="4" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            // Delete note confirm modal
            var deleteNoteModal = document.getElementById('deleteNoteModal');
            var deleteNoteConfirmBtn = document.getElementById('delete-note-confirm-btn');
            if (deleteNoteModal && deleteNoteConfirmBtn) {
                var pendingNoteFormId;
                deleteNoteModal.addEventListener('show.bs.modal', function (e) {
                    pendingNoteFormId = e.relatedTarget && e.relatedTarget.dataset.confirmFormId;
                });
                deleteNoteConfirmBtn.addEventListener('click', function () {
                    if (pendingNoteFormId) document.getElementById(pendingNoteFormId).submit();
                });
            }
            // Delete programme confirm modal
            var deleteProgrammeModal = document.getElementById('deleteProgrammeModal');
            var deleteProgrammeConfirmBtn = document.getElementById('delete-programme-confirm-btn');
            if (deleteProgrammeModal && deleteProgrammeConfirmBtn) {
                var pendingProgrammeFormId;
                deleteProgrammeModal.addEventListener('show.bs.modal', function (e) {
                    pendingProgrammeFormId = e.relatedTarget && e.relatedTarget.dataset.confirmFormId;
                });
                deleteProgrammeConfirmBtn.addEventListener('click', function () {
                    if (pendingProgrammeFormId) document.getElementById(pendingProgrammeFormId).submit();
                });
            }
        })();
        (function () {
            var modalEl = document.getElementById('editNoteModal');
            if (!modalEl || !window.bootstrap) {
                return;
            }
            var modal = window.bootstrap.Modal.getOrCreateInstance(modalEl);
            var form = document.getElementById('editNoteForm');
            var typeInput = document.getElementById('editNoteType');
            var textInput = document.getElementById('editNoteText');
            var caseId = '@Model.Case.TreatmentCaseId';
            document.querySelectorAll('[data-edit-note]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var noteId = btn.getAttribute('data-note-id');
                    typeInput.value = btn.getAttribute('data-note-type') || '';
                    textInput.value = btn.getAttribute('data-note-text') || '';
                    form.action = '/Cases/' + caseId + '/Notes/' + noteId + '/Update';
                    modal.show();
                });
            });
        })();
    </script>
}
