@model CaseDetailPageVm
@{
    ViewData["Title"] = $"Case: {Model.Case.CaseTitle}";
    var caseProgrammeMessage = TempData["CaseProgrammeMessage"] as string;
    var caseProgrammeMessageType = TempData["CaseProgrammeMessageType"] as string ?? "success";
}

<p><a asp-controller="Cases" asp-action="Index">&larr; All cases</a></p>

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1>@Model.Case.CaseTitle</h1>
        <p class="text-muted mb-0">Case #@Model.Case.TreatmentCaseId · <strong>@Model.Case.Status</strong> ·
            @Model.Case.StartDate.ToString("yyyy-MM-dd")@(Model.Case.EndDate is { } end ? " – " + end.ToString("yyyy-MM-dd") : "")</p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Cases" asp-action="Edit" asp-route-id="@Model.Case.TreatmentCaseId">Edit case</a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Patient</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8"><a asp-controller="Pets" asp-action="Details" asp-route-id="@Model.Case.PetId">@Model.Case.PetName</a></dd>
                    <dt class="col-sm-4">Breed</dt>
                    <dd class="col-sm-8">@(Model.Case.PetBreed ?? "—")</dd>
                    <dt class="col-sm-4">Sex</dt>
                    <dd class="col-sm-8">@(Model.Case.PetSex ?? "—")</dd>
                    <dt class="col-sm-4">Weight</dt>
                    <dd class="col-sm-8">@(Model.Case.PetWeight is { } w ? $"{w:0.0} kg" : "—")</dd>
                    <dt class="col-sm-4">Age</dt>
                    <dd class="col-sm-8">@(Model.Case.PetAge is { } a ? a.ToString() : "—")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Owner</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Case.OwnerName</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Case.OwnerEmail</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Case.ClinicalSummary))
{
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h4">Clinical summary</h2>
            <p class="mb-0">@Model.Case.ClinicalSummary</p>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Case notes</h2>
                @if (Model.Case.Notes.Count == 0)
                {
                    <div class="alert alert-info mb-0">No case notes recorded yet.</div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var note in Model.Case.Notes)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start">
                                    <strong>@(string.IsNullOrWhiteSpace(note.NoteType) ? "Clinical note" : note.NoteType)</strong>
                                    <span class="text-muted">@note.CreatedDate.ToString("yyyy-MM-dd HH:mm")</span>
                                </div>
                                <p class="mb-0 mt-2">@note.NoteText</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Add case note</h2>
                <form asp-action="Notes" asp-route-id="@Model.Case.TreatmentCaseId" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="NewNote.NoteType" class="form-label"></label>
                        <input asp-for="NewNote.NoteType" class="form-control" />
                        <span asp-validation-for="NewNote.NoteType" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewNote.NoteText" class="form-label"></label>
                        <textarea asp-for="NewNote.NoteText" class="form-control" rows="6"></textarea>
                        <span asp-validation-for="NewNote.NoteText" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Add note</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2 class="h4 mb-0">Programmes</h2>
        <p class="text-muted mb-0">Create a draft programme for this case or open an existing builder.</p>
    </div>
    <form asp-action="CreateProgramme" asp-route-id="@Model.Case.TreatmentCaseId" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary">Create draft programme</button>
    </form>
</div>

@if (Model.Case.Programmes.Count == 0)
{
    <div class="alert alert-info">No programmes on this case yet.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Sessions</th>
                        <th>Exercises</th>
                        <th>Start</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Case.Programmes.OrderBy(p => p.StartDate))
                    {
                        var status = p.Status?.Trim().ToLowerInvariant() ?? string.Empty;
                        var statusFormId = $"programme-status-{p.ProgrammeId}";
                        var statusOptions = status switch
                        {
                            "planned" => new[] { "planned", "active" },
                            "active" => new[] { "active", "completed" },
                            "completed" => new[] { "completed" },
                            _ => new[] { status },
                        };
                        <tr>
                            <td>@p.ProgrammeName</td>
                            <td>
                                <select name="targetStatus"
                                        class="form-select form-select-sm"
                                        form="@statusFormId"
                                        aria-label="Programme status">
                                    @foreach (var option in statusOptions)
                                    {
                                        var isSelected = string.Equals(option, status, StringComparison.OrdinalIgnoreCase);
                                        var optionLabel = string.IsNullOrWhiteSpace(option)
                                            ? "Unknown"
                                            : char.ToUpperInvariant(option[0]) + option[1..];
                                        <option value="@option" selected="@isSelected">@optionLabel</option>
                                    }
                                </select>
                            </td>
                            <td>@p.SessionCount</td>
                            <td>@p.ExerciseCount</td>
                            <td>@p.StartDate.ToString("yyyy-MM-dd")</td>
                            <td class="text-end d-flex justify-content-end gap-2">
                                <form id="@statusFormId"
                                      asp-action="UpdateProgrammeStatus"
                                      asp-route-id="@Model.Case.TreatmentCaseId"
                                      asp-route-programmeId="@p.ProgrammeId"
                                      method="post"
                                      class="d-none">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="currentStatus" value="@status" />
                                </form>
                                <button type="submit" form="@statusFormId" class="btn btn-sm btn-outline-secondary">Apply</button>
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Programmes" asp-action="Builder"
                                   asp-route-id="@p.ProgrammeId">Builder</a>
                                <a class="btn btn-sm btn-outline-secondary" asp-controller="Programmes" asp-action="Preview"
                                   asp-route-id="@p.ProgrammeId" target="_blank">Preview</a>
                                <form asp-action="DeleteProgramme"
                                      asp-route-id="@Model.Case.TreatmentCaseId"
                                      asp-route-programmeId="@p.ProgrammeId"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Delete this programme? This action cannot be undone.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            aria-label="Delete programme @p.ProgrammeName"
                                            title="Delete programme">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0A.5.5 0 0 1 8.5 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z" />
                                            <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1 0-2H5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1h2.5a1 1 0 0 1 1 1ZM6 2v.5h4V2H6ZM4 4v9a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4H4Z" />
                                        </svg>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(caseProgrammeMessage))
{
    <div id="case-programme-message" class="alert alert-@caseProgrammeMessageType mt-3" role="alert">@caseProgrammeMessage</div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (!string.IsNullOrEmpty(caseProgrammeMessage))
    {
        <text>
        <script>
            window.requestAnimationFrame(function () {
                window.scrollTo({ top: document.body.scrollHeight, behavior: 'auto' });
            });
        </script>
        </text>
    }
}
