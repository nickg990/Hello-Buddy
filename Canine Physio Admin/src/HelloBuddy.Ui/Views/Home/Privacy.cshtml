@{
    ViewData["Title"] = "Privacy and Data Rights";
}
<h1>@ViewData["Title"]</h1>

@if (TempData["Saved"] is string saved)
{
    <div class="alert alert-success" role="status">@saved</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger" role="alert">@error</div>
}

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h4">GDPR and the right to be forgotten</h2>
        <p class="mb-2">
            Under UK GDPR and EU GDPR principles, data subjects can request erasure of personal data when there is no overriding lawful basis to retain it.
            In a clinical context, this action must be controlled, intentional, and fully auditable.
        </p>
        <p class="mb-0">
            Use the right-to-be-forgotten action below only when a valid erasure request has been approved.
        </p>
    </div>
</div>

<div class="card border-danger">
    <div class="card-body">
        <h2 class="h4 text-danger">Right to be forgotten</h2>
        <p class="mb-2">
            This applies GDPR data control for a selected owner. If no linked clinical records exist, the owner is deleted.
            If linked clinical records exist, owner personal data is anonymised and clinical records are retained.
        </p>
        <div class="alert alert-warning" role="alert">
            Warning: this action cannot be reversed. Once personal data is anonymised or deleted, it cannot be restored.
        </div>

        <form asp-action="RightToBeForgotten" method="post" class="row g-3" onsubmit="return confirm('Apply right-to-be-forgotten data control for this owner? This action cannot be reversed.');">
            @Html.AntiForgeryToken()
            <div class="col-sm-6 col-md-4">
                <label class="form-label" for="ownerId">Owner ID</label>
                <input class="form-control" type="number" min="1" step="1" id="ownerId" name="ownerId" required />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-danger">Apply right to be forgotten</button>
            </div>
        </form>
    </div>
</div>
