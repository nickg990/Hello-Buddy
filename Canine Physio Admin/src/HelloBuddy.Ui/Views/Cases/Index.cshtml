@model IReadOnlyList<HelloBuddy.Contracts.CaseRow>
@{
    ViewData["Title"] = "Cases";
}

<h1>Treatment cases</h1>
<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">List, create, and maintain treatment cases for the current practitioner.</p>
    <a class="btn btn-primary" asp-action="Create">Add treatment case</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No cases found for the seeded practitioner.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Pet</th>
                <th>Owner</th>
                <th>Status</th>
                <th>Start</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.TreatmentCaseId</td>
                    <td><a asp-controller="CaseDetail" asp-action="Index" asp-route-id="@row.TreatmentCaseId">@row.CaseTitle</a>
                    </td>
                    <td>@row.PetName</td>
                    <td>@row.OwnerName</td>
                    <td>@row.Status</td>
                    <td>@row.StartDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@row.TreatmentCaseId">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
