@model CaseEditorVm
@{
    var isCreate = !Model.TreatmentCaseId.HasValue;
    ViewData["Title"] = isCreate ? "Add treatment case" : "Edit treatment case";
}

<p><a asp-action="Index">&larr; All cases</a></p>

<h1>@ViewData["Title"]</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Form.PetId" class="form-label">Pet</label>
            <select asp-for="Form.PetId" asp-items="Model.PetOptions" class="form-select"></select>
            <span asp-validation-for="Form.PetId" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Form.Status" class="form-label"></label>
            <select asp-for="Form.Status" class="form-select">
                <option value="planned">Planned</option>
                <option value="active">Active</option>
                <option value="completed">Completed</option>
                <option value="cancelled">Cancelled</option>
            </select>
            <span asp-validation-for="Form.Status" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Form.CaseTitle" class="form-label"></label>
            <input asp-for="Form.CaseTitle" class="form-control" />
            <span asp-validation-for="Form.CaseTitle" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Form.StartDate" class="form-label"></label>
            <input asp-for="Form.StartDate" class="form-control" />
            <span asp-validation-for="Form.StartDate" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Form.EndDate" class="form-label"></label>
            <input asp-for="Form.EndDate" class="form-control" />
            <span asp-validation-for="Form.EndDate" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Form.ClinicalSummary" class="form-label"></label>
            <textarea asp-for="Form.ClinicalSummary" class="form-control" rows="6"></textarea>
            <span asp-validation-for="Form.ClinicalSummary" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save case</button>
        @if (!isCreate)
        {
            <a class="btn btn-outline-secondary" asp-controller="CaseDetail" asp-action="Index" asp-route-id="@Model.TreatmentCaseId">Cancel</a>
        }
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}