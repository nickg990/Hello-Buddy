@model ExerciseDetailVm
@{
    ViewData["Title"] = Model.Title;

    var videoUrl = Model.VideoUrl?.Trim();
    var hasValidVideoUrl = Uri.TryCreate(videoUrl, UriKind.Absolute, out var parsedVideoUrl)
        && (parsedVideoUrl.Scheme == Uri.UriSchemeHttp || parsedVideoUrl.Scheme == Uri.UriSchemeHttps);
    var safeVideoUrl = hasValidVideoUrl ? parsedVideoUrl!.ToString() : string.Empty;
}

<p><a asp-action="Index">&larr; Exercise library</a></p>

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1>@Model.Title</h1>
        <p class="text-muted mb-0">Exercise key: @Model.ExerciseKey</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.ExerciseId">Edit exercise</a>
        <form method="post" asp-action="SetActive" asp-route-id="@Model.ExerciseId">
            @Html.AntiForgeryToken()
            <input type="hidden" name="isActive" value="@(!Model.IsActive).ToString().ToLowerInvariant()" />
            <button type="submit" class="btn btn-outline-primary">@(Model.IsActive ? "Deactivate" : "Activate")</button>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Exercise details</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@(Model.CategoryName ?? "-")</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@(Model.IsActive ? "Active" : "Inactive")</dd>
                    <dt class="col-sm-4">Summary</dt>
                    <dd class="col-sm-8">@(Model.ObjectiveSummary ?? "-")</dd>
                    <dt class="col-sm-4">Updated</dt>
                    <dd class="col-sm-8">@Model.UpdatedDate.ToString("dd MMM yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Prescription defaults</h2>
                <dl class="row mb-3">
                    <dt class="col-sm-4">Reps</dt>
                    <dd class="col-sm-8">@(Model.DefaultReps?.ToString() ?? "-")</dd>
                    <dt class="col-sm-4">Sets</dt>
                    <dd class="col-sm-8">@(Model.DefaultSets?.ToString() ?? "-")</dd>
                    <dt class="col-sm-4">Hold seconds</dt>
                    <dd class="col-sm-8">@(Model.DefaultHoldSeconds?.ToString() ?? "-")</dd>
                </dl>

                <h2 class="h4">Media</h2>
                <div class="d-flex flex-wrap gap-3">
                    <div>
                        <label class="form-label">Image</label>
                        <div class="exercise-media-panel exercise-media-panel--tile border rounded p-2 d-flex align-items-center justify-content-center bg-light overflow-hidden">
                            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                            {
                                <a asp-action="Image" asp-route-id="@Model.ExerciseId" target="_blank" rel="noopener noreferrer" title="Open image in new tab" class="d-inline-flex">
                                    <img src="@Url.Action("Image", "Exercises", new { id = Model.ExerciseId })" alt="@Model.Title image" class="exercise-media-item exercise-media-item--contain" />
                                </a>
                            }
                            else
                            {
                                <partial name="_NoImagePlaceholder" model="@("No image")" />
                            }
                        </div>
                    </div>

                    <div>
                        <label class="form-label">Video</label>
                        <div class="exercise-media-panel exercise-media-panel--tile border rounded p-2 d-flex align-items-center justify-content-center bg-light overflow-hidden">
                            @if (!string.IsNullOrWhiteSpace(safeVideoUrl))
                            {
                                <a id="details-video-link" href="@safeVideoUrl" target="_blank" rel="noopener noreferrer" title="Open video in new tab" class="d-inline-flex flex-column align-items-center text-decoration-none">
                                    <img id="details-video-thumb" src="#" alt="Video preview" class="exercise-media-item exercise-media-item--cover d-none" />
                                    <video id="details-video-player" class="exercise-media-item exercise-media-item--cover exercise-media-video d-none" muted playsinline preload="metadata"></video>
                                    <div id="details-video-fallback" class="text-center text-muted">
                                        <span class="fs-1" aria-hidden="true">&#9658;</span>
                                            <div class="small">Video</div>
                                    </div>
                                </a>
                            }
                            else
                            {
                                <div class="text-center text-muted">
                                    <span class="fs-1" aria-hidden="true">&#9658;</span>
                                    <div class="small">No video</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h4">Ordered instructions</h2>
        @if (Model.Instructions.Count == 0)
        {
            <p class="text-muted mb-0">No instructions saved.</p>
        }
        else
        {
            <ol class="mb-0">
                @foreach (var step in Model.Instructions.OrderBy(x => x.StepNumber))
                {
                    <li>@step.InstructionText</li>
                }
            </ol>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.LegacyInstructionsText))
{
    <div class="alert alert-secondary mb-0">
        <h2 class="h6">Legacy free-text instructions</h2>
        <p class="mb-0">@Model.LegacyInstructionsText</p>
    </div>
}

@section Scripts {
    <script>
        (function () {
            const link = document.getElementById('details-video-link');
            const thumb = document.getElementById('details-video-thumb');
            const player = document.getElementById('details-video-player');
            const fallback = document.getElementById('details-video-fallback');

            if (!link || !thumb || !player || !fallback) {
                return;
            }

            function extractYouTubeId(url) {
                try {
                    const parsed = new URL(url);
                    const host = parsed.hostname.toLowerCase();
                    if (host.includes('youtube.com')) {
                        const id = parsed.searchParams.get('v');
                        return id && id.trim() ? id.trim() : null;
                    }

                    if (host === 'youtu.be') {
                        const path = parsed.pathname.replace(/^\//, '').split('/')[0];
                        return path ? path : null;
                    }
                } catch {
                }
                return null;
            }

            function extractVimeoId(url) {
                try {
                    const parsed = new URL(url);
                    if (!parsed.hostname.toLowerCase().includes('vimeo.com')) {
                        return null;
                    }

                    const segments = parsed.pathname.split('/').filter(Boolean);
                    for (let i = segments.length - 1; i >= 0; i--) {
                        if (/^\d+$/.test(segments[i])) {
                            return segments[i];
                        }
                    }
                } catch {
                }
                return null;
            }

            function isDirectVideoUrl(url) {
                return /\.(mp4|webm|ogg|mov)(\?|#|$)/i.test(url);
            }

            function extractGoogleDriveId(url) {
                try {
                    const parsed = new URL(url);
                    if (!parsed.hostname.toLowerCase().includes('drive.google.com')) {
                        return null;
                    }

                    const fileMatch = parsed.pathname.match(/\/file\/d\/([^/]+)/);
                    if (fileMatch && fileMatch[1]) {
                        return fileMatch[1];
                    }

                    const idParam = parsed.searchParams.get('id');
                    if (idParam && idParam.trim()) {
                        return idParam.trim();
                    }
                } catch {
                }

                return null;
            }

            function resolveVideoPreview(url) {
                const youtubeId = extractYouTubeId(url);
                if (youtubeId) {
                    return { type: 'thumb', src: 'https://img.youtube.com/vi/' + youtubeId + '/hqdefault.jpg' };
                }

                const vimeoId = extractVimeoId(url);
                if (vimeoId) {
                    return { type: 'thumb', src: 'https://vumbnail.com/' + vimeoId + '.jpg' };
                }

                const driveId = extractGoogleDriveId(url);
                if (driveId) {
                    return { type: 'thumb', src: 'https://drive.google.com/thumbnail?id=' + driveId + '&sz=w640' };
                }

                if (isDirectVideoUrl(url)) {
                    return { type: 'video', src: url };
                }

                return { type: 'fallback', src: null };
            }

            const preview = resolveVideoPreview(link.href);
            if (preview.type === 'thumb') {
                thumb.src = preview.src;
                thumb.classList.remove('d-none');
                fallback.classList.add('d-none');
                return;
            }

            if (preview.type === 'video') {
                player.src = preview.src;
                player.classList.remove('d-none');
                fallback.classList.add('d-none');
            }
        })();
    </script>
}
