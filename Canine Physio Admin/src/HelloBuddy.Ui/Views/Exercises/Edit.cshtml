@model ExerciseEditorVm
@{
    var isCreate = !Model.ExerciseId.HasValue;
    ViewData["Title"] = isCreate ? "Add exercise" : "Edit exercise";
    var currentVideoUrlRaw = Model.Form.VideoUrl?.Trim() ?? string.Empty;
    var hasValidCurrentVideoUrl = Uri.TryCreate(currentVideoUrlRaw, UriKind.Absolute, out var parsedCurrentVideoUrl)
        && (parsedCurrentVideoUrl.Scheme == Uri.UriSchemeHttp || parsedCurrentVideoUrl.Scheme == Uri.UriSchemeHttps);
    var currentVideoUrl = hasValidCurrentVideoUrl ? parsedCurrentVideoUrl!.ToString() : string.Empty;
}

<div class="mb-3">
@if (isCreate)
{
    <a class="btn btn-outline-secondary" asp-action="Index">&larr; Back to exercise library</a>
}
else
{
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.ExerciseId">&larr; Back to exercise</a>
}
</div>

<h1>@ViewData["Title"]</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-8">
            <label asp-for="Form.Title" class="form-label"></label>
            <input asp-for="Form.Title" class="form-control" />
            <span asp-validation-for="Form.Title" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Form.ExerciseCategoryId" class="form-label">Category</label>
            <select asp-for="Form.ExerciseCategoryId" asp-items="Model.CategoryOptions" class="form-select">
                <option value="">Select category</option>
            </select>
            <span asp-validation-for="Form.ExerciseCategoryId" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Form.ObjectiveSummary" class="form-label">Summary</label>
            <textarea asp-for="Form.ObjectiveSummary" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Form.ObjectiveSummary" class="text-danger"></span>
        </div>

        <div class="col-12">
            <div class="border rounded p-3">
                <h2 class="h6 mb-3">Media</h2>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Form.ImageUrl" class="form-label">Image URL</label>
                        <div class="input-group">
                            <input asp-for="Form.ImageUrl" id="Form_ImageUrl" class="form-control exercise-url-input" placeholder="No image selected" autocomplete="off" />
                            <button id="open-image-search" type="button" class="btn btn-outline-secondary">Search image</button>
                        </div>
                        <span asp-validation-for="Form.ImageUrl" class="text-danger"></span>
                        <div class="form-text">Paste the image URL from blob storage or the shared image library (https://...). Left click selected image to open; right click selected image to deselect.</div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Form.VideoUrl" class="form-label">Video URL</label>
                        <input type="hidden" asp-for="Form.VideoUrl" id="Form_VideoUrl_Hidden" />
                        <div class="input-group">
                            <input type="text" id="Form_VideoUrl" class="form-control exercise-url-input" placeholder="No video selected" autocomplete="off" />
                            <button id="open-video-search" type="button" class="btn btn-outline-secondary">Search video</button>
                        </div>
                        <span asp-validation-for="Form.VideoUrl" class="text-danger"></span>
                        <div class="form-text">Left click current/selected video to open; right click selected video to deselect.</div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-3">
                    @if (!isCreate)
                    {
                        <div>
                            <label class="form-label">Current image</label>
                            <div class="exercise-media-panel exercise-media-panel--tile border rounded p-2 d-flex align-items-center justify-content-center bg-light overflow-hidden">
                                @if (!string.IsNullOrWhiteSpace(Model.Form.ImageUrl))
                                {
                                    <a href="@Model.Form.ImageUrl" target="_blank" rel="noopener noreferrer" title="Open full-size image in new tab" class="d-inline-flex">
                                        <img src="@Model.Form.ImageUrl" alt="Current exercise image" class="exercise-media-item exercise-media-item--contain" />
                                    </a>
                                }
                                else
                                {
                                    <partial name="_NoImagePlaceholder" model="@("No image")" />
                                }
                            </div>
                        </div>
                    }

                    <div>
                        <label class="form-label">@(isCreate ? "Selected image" : "Selected image (pending save)")</label>
                        <div id="selected-image-panel" class="exercise-media-panel exercise-media-panel--tile border rounded p-2 d-flex align-items-center justify-content-center bg-light position-relative overflow-hidden">
                            <div id="selected-image-empty" class="text-center">
                                <partial name="_NoImagePlaceholder" model="@("No image selected")" />
                            </div>
                            <a id="selected-image-link" href="#" target="_blank" rel="noopener noreferrer" class="d-none d-inline-flex" title="Open full-size preview in new tab">
                                <img id="selected-image-preview" src="#" alt="Selected image preview" class="exercise-media-item exercise-media-item--contain" />
                            </a>
                        </div>
                    </div>

                    @if (!isCreate)
                    {
                        <div>
                            <label class="form-label">Current video</label>
                            <div class="exercise-media-panel exercise-media-panel--tile border rounded p-2 d-flex align-items-center justify-content-center bg-light overflow-hidden text-center">
                                @if (!string.IsNullOrWhiteSpace(currentVideoUrl))
                                {
                                    <a id="current-video-link" href="@currentVideoUrl" target="_blank" rel="noopener noreferrer" title="Open current video in new tab" class="d-inline-flex flex-column align-items-center text-decoration-none">
                                        <img id="current-video-thumb" src="#" alt="Current video preview" class="exercise-media-item exercise-media-item--cover d-none" />
                                        <video id="current-video-player" class="exercise-media-item exercise-media-item--cover exercise-media-video d-none" muted playsinline preload="metadata"></video>
                                        <div id="current-video-fallback" class="text-center">
                                            <span class="fs-1" aria-hidden="true">&#9658;</span>
                                            <div class="small">Open current video</div>
                                        </div>
                                    </a>
                                }
                                else
                                {
                                    <div class="text-muted">
                                        <div class="fs-1" aria-hidden="true">&#9658;</div>
                                        <div class="small mt-2">No video</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div>
                        <label class="form-label">@(isCreate ? "Selected video" : "Selected video (pending save)")</label>
                        <div id="selected-video-panel" class="exercise-media-panel exercise-media-panel--tile border rounded p-2 d-flex align-items-center justify-content-center bg-light position-relative overflow-hidden">
                            <div id="selected-video-empty" class="text-muted text-center">
                                <div class="fs-1" aria-hidden="true">&#9658;</div>
                                <div class="small mt-2">No video selected</div>
                            </div>
                            <a id="selected-video-link" href="#" target="_blank" rel="noopener noreferrer" class="d-none d-inline-flex flex-column align-items-center text-decoration-none" title="Open selected video in new tab">
                                <img id="selected-video-thumb" src="#" alt="Selected video preview" class="exercise-media-item exercise-media-item--cover d-none" />
                                <video id="selected-video-player" class="exercise-media-item exercise-media-item--cover exercise-media-video d-none" muted playsinline preload="metadata"></video>
                                <div id="selected-video-fallback" class="text-center">
                                    <span class="fs-1" aria-hidden="true">&#9658;</span>
                                    <span id="selected-video-text" class="small d-block">Open selected video</span>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="border rounded p-3">
                <h2 class="h6 mb-3">Defaults</h2>
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Is active</label>
                        <div class="form-check mt-2">
                            <input asp-for="Form.IsActive" class="form-check-input" />
                            <label asp-for="Form.IsActive" class="form-check-label">Active exercise</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Form.DefaultReps" class="form-label"></label>
                        <input asp-for="Form.DefaultReps" class="form-control" />
                        <span asp-validation-for="Form.DefaultReps" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Form.DefaultSets" class="form-label"></label>
                        <input asp-for="Form.DefaultSets" class="form-control" />
                        <span asp-validation-for="Form.DefaultSets" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Form.DefaultHoldSeconds" class="form-label"></label>
                        <input asp-for="Form.DefaultHoldSeconds" class="form-control" />
                        <span asp-validation-for="Form.DefaultHoldSeconds" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <label asp-for="InstructionsText" class="form-label">Ordered instructions (one step per line)</label>
            <textarea asp-for="InstructionsText" class="form-control" rows="7"></textarea>
            <span asp-validation-for="InstructionsText" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save exercise</button>
        @if (!isCreate)
        {
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.ExerciseId">Cancel</a>
        }
    </div>
</form>

<div id="video-search-backdrop" class="exercise-video-search-backdrop d-none position-fixed top-0 start-0 w-100 h-100"></div>
<div id="video-search-popup" class="exercise-video-search-popup d-none position-fixed bg-white border rounded shadow p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="h6 m-0">Search for video URL</h3>
        <button id="close-video-search" type="button" class="btn btn-sm btn-outline-secondary">Close</button>
    </div>
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label for="video-search-term" class="form-label">Search term</label>
            <input id="video-search-term" class="form-control" placeholder="e.g. canine physio step up exercise" />
        </div>
        <div class="col-md-4">
            <label for="video-search-provider" class="form-label">Provider</label>
            <select id="video-search-provider" class="form-select">
                @foreach (var provider in Model.VideoSearchProviders)
                {
                    <option value="@provider.BaseUrl">@provider.Description</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button id="run-video-search" type="button" class="btn btn-primary w-100">Search web</button>
        </div>
    </div>
    <div class="form-text mt-2">Search opens in a new tab. Copy the URL of the chosen video and paste it below.</div>
    <div class="mt-3">
        <label for="video-selected-url" class="form-label">Selected video URL</label>
        <div class="input-group">
            <input id="video-selected-url" class="form-control exercise-url-input" placeholder="No video selected" />
            <button id="apply-video-selected-url" type="button" class="btn btn-outline-secondary">Use URL</button>
        </div>
    </div>
</div>

<div id="image-search-backdrop" class="exercise-video-search-backdrop d-none position-fixed top-0 start-0 w-100 h-100"></div>
<div id="image-search-popup" class="exercise-video-search-popup d-none position-fixed bg-white border rounded shadow p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="h6 m-0">Search for image URL</h3>
        <button id="close-image-search" type="button" class="btn btn-sm btn-outline-secondary">Close</button>
    </div>
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label for="image-search-term" class="form-label">Search term</label>
            <input id="image-search-term" class="form-control" placeholder="e.g. canine physio step up exercise" />
        </div>
        <div class="col-md-4">
            <label for="image-search-provider" class="form-label">Provider</label>
            <select id="image-search-provider" class="form-select">
                @if (!string.IsNullOrWhiteSpace(Model.ImageLibraryUrl))
                {
                    <option value="@Model.ImageLibraryUrl">Image library</option>
                }
                else
                {
                    <option value="">No image library configured (set it in Settings)</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button id="run-image-search" type="button" class="btn btn-primary w-100">Open library</button>
        </div>
    </div>
    <div class="form-text mt-2">Opens the shared image library in a new tab. Copy the URL of the chosen image and paste it below.</div>
    <div id="image-search-error" class="alert alert-warning d-none mt-2 mb-0 py-2 px-3 small" role="alert"></div>
    <div class="mt-3">
        <label for="image-selected-url" class="form-label">Selected image URL</label>
        <div class="input-group">
            <input id="image-selected-url" class="form-control exercise-url-input" placeholder="No image selected" />
            <button id="apply-image-selected-url" type="button" class="btn btn-outline-secondary">Use URL</button>
        </div>
    </div>
</div>

<div id="selected-media-context-menu" class="exercise-media-context-menu d-none position-fixed bg-white border rounded shadow-sm py-1">
    <button id="selected-media-deselect" type="button" class="btn btn-link text-start text-decoration-none w-100 px-3 py-1">Deselect</button>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const imageInput = document.getElementById('Form_ImageUrl');
            const selectedImageEmpty = document.getElementById('selected-image-empty');
            const selectedImageLink = document.getElementById('selected-image-link');
            const selectedImagePreview = document.getElementById('selected-image-preview');

            const videoInput = document.getElementById('Form_VideoUrl');
            const hiddenVideoInput = document.getElementById('Form_VideoUrl_Hidden');
            const selectedVideoEmpty = document.getElementById('selected-video-empty');
            const selectedVideoLink = document.getElementById('selected-video-link');
            const selectedVideoText = document.getElementById('selected-video-text');
            const selectedVideoThumb = document.getElementById('selected-video-thumb');
            const selectedVideoPlayer = document.getElementById('selected-video-player');
            const selectedVideoFallback = document.getElementById('selected-video-fallback');

            const currentVideoLink = document.getElementById('current-video-link');
            const currentVideoThumb = document.getElementById('current-video-thumb');
            const currentVideoPlayer = document.getElementById('current-video-player');
            const currentVideoFallback = document.getElementById('current-video-fallback');

            const contextMenu = document.getElementById('selected-media-context-menu');
            const contextMenuDeselect = document.getElementById('selected-media-deselect');

            const videoSearchBackdrop = document.getElementById('video-search-backdrop');
            const videoSearchPopup = document.getElementById('video-search-popup');
            const openVideoSearch = document.getElementById('open-video-search');
            const closeVideoSearch = document.getElementById('close-video-search');
            const runVideoSearch = document.getElementById('run-video-search');
            const applyVideoSelectedUrl = document.getElementById('apply-video-selected-url');
            const videoSearchProvider = document.getElementById('video-search-provider');
            const videoSearchTerm = document.getElementById('video-search-term');
            const videoSelectedUrl = document.getElementById('video-selected-url');

            const imageSearchBackdrop = document.getElementById('image-search-backdrop');
            const imageSearchPopup = document.getElementById('image-search-popup');
            const openImageSearch = document.getElementById('open-image-search');
            const closeImageSearch = document.getElementById('close-image-search');
            const runImageSearch = document.getElementById('run-image-search');
            const applyImageSelectedUrl = document.getElementById('apply-image-selected-url');
            const imageSearchProvider = document.getElementById('image-search-provider');
            const imageSearchTerm = document.getElementById('image-search-term');
            const imageSelectedUrl = document.getElementById('image-selected-url');
            const imageSearchError = document.getElementById('image-search-error');

            if (!imageInput || !selectedImageEmpty || !selectedImageLink || !selectedImagePreview || !videoInput || !hiddenVideoInput || !selectedVideoEmpty || !selectedVideoLink || !selectedVideoText || !selectedVideoThumb || !selectedVideoPlayer || !selectedVideoFallback || !contextMenu || !contextMenuDeselect || !videoSearchBackdrop || !videoSearchPopup || !openVideoSearch || !closeVideoSearch || !runVideoSearch || !applyVideoSelectedUrl || !videoSearchProvider || !videoSearchTerm || !videoSelectedUrl || !imageSearchBackdrop || !imageSearchPopup || !openImageSearch || !closeImageSearch || !runImageSearch || !applyImageSelectedUrl || !imageSearchProvider || !imageSearchTerm || !imageSelectedUrl || !imageSearchError) {
                return;
            }

            let contextTarget = null;

            function resetSelectedImagePreview() {
                selectedImageLink.classList.add('d-none');
                selectedImageEmpty.classList.remove('d-none');
                selectedImagePreview.src = '#';
                selectedImageLink.href = '#';
            }

            function updateSelectedImagePanel() {
                const raw = imageInput.value ? imageInput.value.trim() : '';
                if (!isHttpUrl(raw)) {
                    resetSelectedImagePreview();
                    return;
                }

                selectedImagePreview.src = raw;
                selectedImageLink.href = raw;
                selectedImageLink.classList.remove('d-none');
                selectedImageEmpty.classList.add('d-none');
            }

            function isHttpUrl(value) {
                if (!value) {
                    return false;
                }

                try {
                    const parsed = new URL(value);
                    return parsed.protocol === 'http:' || parsed.protocol === 'https:';
                } catch {
                    return false;
                }
            }

            function extractYouTubeId(url) {
                try {
                    const parsed = new URL(url);
                    const host = parsed.hostname.toLowerCase();
                    if (host.includes('youtube.com')) {
                        const id = parsed.searchParams.get('v');
                        return id && id.trim() ? id.trim() : null;
                    }

                    if (host === 'youtu.be') {
                        const path = parsed.pathname.replace(/^\//, '').split('/')[0];
                        return path ? path : null;
                    }
                } catch {
                }

                return null;
            }

            function extractVimeoId(url) {
                try {
                    const parsed = new URL(url);
                    if (!parsed.hostname.toLowerCase().includes('vimeo.com')) {
                        return null;
                    }

                    const segments = parsed.pathname.split('/').filter(Boolean);
                    for (let i = segments.length - 1; i >= 0; i--) {
                        if (/^\d+$/.test(segments[i])) {
                            return segments[i];
                        }
                    }
                } catch {
                }

                return null;
            }

            function isDirectVideoUrl(url) {
                return /\.(mp4|webm|ogg|mov)(\?|#|$)/i.test(url);
            }

            function extractGoogleDriveId(url) {
                try {
                    const parsed = new URL(url);
                    if (!parsed.hostname.toLowerCase().includes('drive.google.com')) {
                        return null;
                    }

                    const fileMatch = parsed.pathname.match(/\/file\/d\/([^/]+)/);
                    if (fileMatch && fileMatch[1]) {
                        return fileMatch[1];
                    }

                    const idParam = parsed.searchParams.get('id');
                    if (idParam && idParam.trim()) {
                        return idParam.trim();
                    }
                } catch {
                }

                return null;
            }

            function resolveVideoPreview(url) {
                const youtubeId = extractYouTubeId(url);
                if (youtubeId) {
                    return { type: 'thumb', src: 'https://img.youtube.com/vi/' + youtubeId + '/hqdefault.jpg' };
                }

                const vimeoId = extractVimeoId(url);
                if (vimeoId) {
                    return { type: 'thumb', src: 'https://vumbnail.com/' + vimeoId + '.jpg' };
                }

                const driveId = extractGoogleDriveId(url);
                if (driveId) {
                    return { type: 'thumb', src: 'https://drive.google.com/thumbnail?id=' + driveId + '&sz=w640' };
                }

                if (isDirectVideoUrl(url)) {
                    return { type: 'video', src: url };
                }

                return { type: 'fallback', src: null };
            }

            function renderVideoPreview(link, thumb, player, fallback, url) {
                thumb.classList.add('d-none');
                player.classList.add('d-none');
                fallback.classList.remove('d-none');
                thumb.src = '#';
                player.removeAttribute('src');
                player.load();

                const preview = resolveVideoPreview(url);
                if (preview.type === 'thumb') {
                    thumb.src = preview.src;
                    thumb.classList.remove('d-none');
                    fallback.classList.add('d-none');
                    return;
                }

                if (preview.type === 'video') {
                    player.src = preview.src;
                    player.classList.remove('d-none');
                    fallback.classList.add('d-none');
                }
            }

            function updateSelectedVideoPanel() {
                const raw = videoInput.value ? videoInput.value.trim() : '';
                if (!isHttpUrl(raw)) {
                    selectedVideoLink.classList.add('d-none');
                    selectedVideoEmpty.classList.remove('d-none');
                    selectedVideoLink.href = '#';
                    selectedVideoText.textContent = 'Open selected video';
                    selectedVideoThumb.classList.add('d-none');
                    selectedVideoPlayer.classList.add('d-none');
                    selectedVideoFallback.classList.remove('d-none');
                    return;
                }

                const host = new URL(raw).host;
                selectedVideoLink.href = raw;
                selectedVideoText.textContent = host ? 'Open selected video (' + host + ')' : 'Open selected video';
                selectedVideoLink.classList.remove('d-none');
                selectedVideoEmpty.classList.add('d-none');
                renderVideoPreview(selectedVideoLink, selectedVideoThumb, selectedVideoPlayer, selectedVideoFallback, raw);
            }

            function hideContextMenu() {
                contextMenu.classList.add('d-none');
                contextTarget = null;
            }

            function showContextMenu(x, y, target) {
                contextTarget = target;
                contextMenuDeselect.textContent = target === 'image' ? 'Deselect image' : 'Deselect video';
                contextMenu.style.left = x + 'px';
                contextMenu.style.top = y + 'px';
                contextMenu.classList.remove('d-none');
            }

            function openVideoSearchPopup() {
                videoSearchBackdrop.classList.remove('d-none');
                videoSearchPopup.classList.remove('d-none');
                videoSelectedUrl.value = '';
            }

            function closeVideoSearchPopup() {
                videoSearchPopup.classList.add('d-none');
                videoSearchBackdrop.classList.add('d-none');
            }

            function openImageSearchPopup() {
                imageSearchBackdrop.classList.remove('d-none');
                imageSearchPopup.classList.remove('d-none');
                imageSelectedUrl.value = '';
                imageSearchError.classList.add('d-none');
                imageSearchError.textContent = '';
            }

            function closeImageSearchPopup() {
                imageSearchPopup.classList.add('d-none');
                imageSearchBackdrop.classList.add('d-none');
            }

            imageInput.addEventListener('input', updateSelectedImagePanel);

            videoInput.addEventListener('input', function () {
                hiddenVideoInput.value = videoInput.value.trim();
                updateSelectedVideoPanel();
            });

            selectedImageLink.addEventListener('contextmenu', function (e) {
                if (selectedImageLink.classList.contains('d-none')) {
                    return;
                }
                e.preventDefault();
                showContextMenu(e.pageX, e.pageY, 'image');
            });

            selectedVideoLink.addEventListener('contextmenu', function (e) {
                if (selectedVideoLink.classList.contains('d-none')) {
                    return;
                }
                e.preventDefault();
                showContextMenu(e.pageX, e.pageY, 'video');
            });

            contextMenuDeselect.addEventListener('click', function () {
                if (contextTarget === 'image') {
                    imageInput.value = '';
                    updateSelectedImagePanel();
                } else if (contextTarget === 'video') {
                    videoInput.value = '';
                    hiddenVideoInput.value = '';
                    updateSelectedVideoPanel();
                }
                hideContextMenu();
            });

            document.addEventListener('click', function (e) {
                if (!contextMenu.contains(e.target)) {
                    hideContextMenu();
                }
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    hideContextMenu();
                    closeVideoSearchPopup();
                    closeImageSearchPopup();
                }
            });

            openVideoSearch.addEventListener('click', openVideoSearchPopup);
            closeVideoSearch.addEventListener('click', closeVideoSearchPopup);
            videoSearchBackdrop.addEventListener('click', closeVideoSearchPopup);

            runVideoSearch.addEventListener('click', function () {
                const providerBaseUrl = (videoSearchProvider.value || '').trim();
                if (!providerBaseUrl) {
                    return;
                }

                const term = (videoSearchTerm.value || '').trim();
                let url = providerBaseUrl;

                if (providerBaseUrl.includes('{query}')) {
                    url = providerBaseUrl.replace('{query}', encodeURIComponent(term));
                }

                window.open(url, '_blank', 'noopener');
            });

            applyVideoSelectedUrl.addEventListener('click', function () {
                videoInput.value = (videoSelectedUrl.value || '').trim();
                hiddenVideoInput.value = videoInput.value;
                updateSelectedVideoPanel();
                closeVideoSearchPopup();
            });

            openImageSearch.addEventListener('click', openImageSearchPopup);
            closeImageSearch.addEventListener('click', closeImageSearchPopup);
            imageSearchBackdrop.addEventListener('click', closeImageSearchPopup);

            runImageSearch.addEventListener('click', function () {
                const providerBaseUrl = (imageSearchProvider.value || '').trim();
                if (!providerBaseUrl || !isHttpUrl(providerBaseUrl.replace('{query}', 'x'))) {
                    imageSearchError.textContent = 'No image library found. Set a valid image library URL on the Settings page (File storage) before searching.';
                    imageSearchError.classList.remove('d-none');
                    return;
                }

                imageSearchError.classList.add('d-none');
                imageSearchError.textContent = '';

                const term = (imageSearchTerm.value || '').trim();
                let url = providerBaseUrl;

                if (providerBaseUrl.includes('{query}')) {
                    url = providerBaseUrl.replace('{query}', encodeURIComponent(term));
                }

                window.open(url, '_blank', 'noopener');
            });

            applyImageSelectedUrl.addEventListener('click', function () {
                imageInput.value = (imageSelectedUrl.value || '').trim();
                updateSelectedImagePanel();
                closeImageSearchPopup();
            });

            if (currentVideoLink && currentVideoThumb && currentVideoPlayer && currentVideoFallback) {
                renderVideoPreview(currentVideoLink, currentVideoThumb, currentVideoPlayer, currentVideoFallback, currentVideoLink.href);
            }

            updateSelectedVideoPanel();
            updateSelectedImagePanel();
        })();
    </script>
}

