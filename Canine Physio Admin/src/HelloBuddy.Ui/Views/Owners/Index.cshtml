@model IReadOnlyList<OwnerListItem>
@{
    ViewData["Title"] = "Owners";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Owners</h1>
        <p class="text-muted mb-0">Create and maintain owner contact records.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add owner</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No owners have been added yet.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Pets</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var owner in Model)
            {
                <tr>
                    <td>@owner.FullName</td>
                    <td>@owner.Email</td>
                    <td>@(owner.PhoneNumber ?? "-")</td>
                    <td>@owner.PetCount</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@owner.OwnerId">Open</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}