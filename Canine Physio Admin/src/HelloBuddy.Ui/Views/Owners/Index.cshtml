@model IReadOnlyList<OwnerListItem>
@{
    ViewData["Title"] = "Owners";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Owners</h1>
        <p class="text-muted mb-0">Create and maintain owner contact records.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-action="Create">Add owner</a>
    </div>
</div>

@if (TempData["Saved"] is string saved)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @saved
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-info">No owners have been added yet.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Pets</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var owner in Model)
            {
                <tr>
                    <td>@owner.FullName</td>
                    <td>@owner.Email</td>
                    <td>@(owner.PhoneNumber ?? "-")</td>
                    <td>@owner.PetCount</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Details" asp-route-id="@owner.OwnerId">Open</a>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger delete-owner-btn"
                                data-owner-id="@owner.OwnerId"
                                data-owner-name="@owner.FullName"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteOwnerModal"
                                title="Delete owner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                            </svg>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="modal fade" id="deleteOwnerModal" tabindex="-1" aria-labelledby="deleteOwnerModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteOwnerModalLabel">Delete owner?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete owner <strong id="deleteOwnerName"></strong>?</p>
                <div class="alert alert-warning mb-0" role="alert">
                    <strong>Warning: this action is irreversible.</strong>
                    This will permanently delete the owner, all their pets, case notes, exercise programmes, sessions, and any stored programme PDFs.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteOwnerForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete owner</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('.delete-owner-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = btn.getAttribute('data-owner-id');
                    var name = btn.getAttribute('data-owner-name');
                    document.getElementById('deleteOwnerName').textContent = name;
                    document.getElementById('deleteOwnerForm').action = '/Owners/' + id + '/Delete';
                });
            });
        })();
    </script>
}