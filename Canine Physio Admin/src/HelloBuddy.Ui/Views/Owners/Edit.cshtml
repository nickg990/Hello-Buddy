@model OwnerEditorVm
@{
    var isCreate = !Model.OwnerId.HasValue;
    ViewData["Title"] = isCreate ? "Add owner" : "Edit owner";
}

<div class="mb-3">
@if (isCreate)
{
    <a class="btn btn-outline-secondary" asp-action="Index">&larr; Back to owners</a>
}
else
{
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.OwnerId">&larr; Back to owner</a>
}
</div>

<h1>@ViewData["Title"]</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Form.FirstName" class="form-label"></label>
            <input asp-for="Form.FirstName" class="form-control" />
            <span asp-validation-for="Form.FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Form.LastName" class="form-label"></label>
            <input asp-for="Form.LastName" class="form-control" />
            <span asp-validation-for="Form.LastName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Form.Email" class="form-label"></label>
            <input asp-for="Form.Email" class="form-control" />
            <span asp-validation-for="Form.Email" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Form.PhoneNumber" class="form-label"></label>
            <input asp-for="Form.PhoneNumber" class="form-control" />
            <span asp-validation-for="Form.PhoneNumber" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Form.AddressLine1" class="form-label"></label>
            <input asp-for="Form.AddressLine1" class="form-control" />
            <span asp-validation-for="Form.AddressLine1" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Form.AddressLine2" class="form-label"></label>
            <input asp-for="Form.AddressLine2" class="form-control" />
            <span asp-validation-for="Form.AddressLine2" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Form.Town" class="form-label"></label>
            <input asp-for="Form.Town" class="form-control" />
            <span asp-validation-for="Form.Town" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Form.Postcode" class="form-label"></label>
            <input asp-for="Form.Postcode" class="form-control" />
            <span asp-validation-for="Form.Postcode" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save owner</button>
        @if (!isCreate)
        {
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.OwnerId">Cancel</a>
        }
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}