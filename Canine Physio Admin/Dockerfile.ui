# syntax=docker/dockerfile:1.7
# UI image — Razor MVC over the API. No Chromium needed.

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY Directory.Build.props Directory.Packages.props ./
COPY src/HelloBuddy.Contracts/HelloBuddy.Contracts.csproj  src/HelloBuddy.Contracts/
COPY src/HelloBuddy.Ui/HelloBuddy.Ui.csproj                src/HelloBuddy.Ui/
RUN dotnet restore src/HelloBuddy.Ui/HelloBuddy.Ui.csproj

COPY src/ src/
RUN dotnet publish src/HelloBuddy.Ui/HelloBuddy.Ui.csproj \
    -c Release \
    -o /app/publish \
    --no-restore \
    /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app

ENV ASPNETCORE_URLS=http://+:8080 \
    DOTNET_RUNNING_IN_CONTAINER=true

COPY --from=build /app/publish ./

EXPOSE 8080
ENTRYPOINT ["dotnet", "HelloBuddy.Ui.dll"]
